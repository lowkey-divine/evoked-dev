---
/**
 * OrionFigure - parameterized scholarly star-chart figure
 *
 * Five cartographic traditions, all citing the same three belt stars of
 * Orion. Citation labels are horizontal HTML (outside the tilted SVG)
 * and reveal on hover/focus.
 *
 * Authored 2026-06-16 by extracting the inline SVG from j.html and the
 * four saved figures at /public/figures/orion/. The structural condition
 * Stirps held at the 2026-06-15 meeting still applies: the citation
 * label must travel with the artifact. Do not suppress the labels
 * without an explicit Stirps Tier-2 review.
 *
 * Usage:
 *   <OrionFigure tradition="bayer" variant="hero" />
 *   <OrionFigure tradition="al-sufi" variant="inline" />
 */
export type Tradition = 'bayer' | 'hevelius' | 'al-sufi' | 'su-song' | 'korean';

interface Props {
  /** Which cartographic tradition to render. */
  tradition: Tradition;
  /** "hero" positions absolutely to the right of a relative parent (big).
      "inline" sits in normal flow at a smaller size. */
  variant?: 'hero' | 'inline';
  /**
   * Citation label visibility pattern.
   * - 'hover': labels hidden by default, reveal on hover/focus. For working surfaces only.
   * - 'low-bright': labels always visible at low opacity, brighten on hover/focus.
   *   Stirps Tier-2 condition for production surfaces (citation always travels with artifact).
   * - 'persistent': labels always visible at full opacity. Cleanest citation discipline.
   *
   * Default 'hover' for backward compat with elevation working drafts.
   * Production pages should use 'low-bright' or 'persistent'.
   */
  citationVisibility?: 'hover' | 'low-bright' | 'persistent';
  /** Opacity for the line-work (frame, grid, figure outline). Default 0.45. */
  linesOpacity?: number;
  /** Opacity for stars + name labels. Default 0.6. */
  starsOpacity?: number;
  /** Override the SVG rotation. Default -12deg. */
  rotate?: number;
  /** Override the right-edge offset for the hero variant. Default -14rem. */
  heroRight?: string;
}

const {
  tradition,
  variant = 'hero',
  citationVisibility = 'hover',
  linesOpacity = 0.45,
  starsOpacity = 0.6,
  rotate = -12,
  heroRight = '-14rem',
} = Astro.props;

// citation metadata per tradition
