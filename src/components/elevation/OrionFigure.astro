const fig = figures[tradition];
const topLabel = fig.topLabel ?? 'ORION';
---

<figure
  class:list={['orion-figure', `orion-${tradition}`, `variant-${variant}`]}
  data-citation={citationVisibility}
  tabindex="0"
  aria-label={fig.aria}
  style={`--orion-rotate:${rotate}deg;--orion-right:${heroRight};`}
>
  <p class="fig-label-top">FIG &middot; {topLabel}</p>
  <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <radialGradient id={`sketch-fade-${tradition}`} cx="50%" cy="50%" r="52%">
        <stop offset="0%" stop-color="#fff" stop-opacity="1"/>
        <stop offset="48%" stop-color="#fff" stop-opacity="1"/>
        <stop offset="80%" stop-color="#fff" stop-opacity="0.55"/>
        <stop offset="100%" stop-color="#fff" stop-opacity="0"/>
      </radialGradient>
      <mask id="sketch-fade-mask">
        <rect width="400" height="400" fill={`url(#sketch-fade-${tradition})`}/>
      </mask>
    </defs>
    <Fragment set:html={fig.svg} />
  </svg>
  <p class="fig-label-bot">After {fig.name}<span class="fig-sep">&middot;</span>{fig.source}<br/>{fig.place}<span class="fig-sep">&middot;</span>{fig.year}</p>
</figure>

<style>
  .orion-figure {
    margin: 0;
    cursor: help;
    outline: none;
  }
  .orion-figure svg {
    width: 100%;
    height: auto;
    display: block;
    transform: rotate(var(--orion-rotate));
    transform-origin: center center;
  }

  /* hero variant - absolutely positioned to the right of a relative parent */
  .orion-figure.variant-hero {
    position: absolute;
    top: 50%;
    right: var(--orion-right);
    width: clamp(520px, 58vw, 800px);
    transform: translateY(calc(-50% - 1.5rem));
    z-index: 1;
