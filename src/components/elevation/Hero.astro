---
/**
 * Hero - the elevation register hero pattern
 *
 * eyebrow → h1 → metaphor → sub → CTAs, with an optional figure
 * (OrionFigure or similar) absolutely positioned to the right.
 * Verbatim from j.html.
 *
 * Usage:
 *   <Hero
 *     eyebrowParts={["By Evoked", "Forming in public", "Vol. 01"]}
 *     headline="The Agentic Standard."
 *     metaphor={["Credentials prove who.", "Provenance proves what survived."]}
 *     sub="Identity, scope, and signed evidence..."
 *   >
 *     <a class="cta cta-primary" href="#what">Read the principles</a>
 *     <a class="cta cta-secondary" href="#where">See the registry →</a>
 *     <OrionFigure slot="figure" tradition="bayer" />
 *   </Hero>
 */
interface Props {
  /** Eyebrow text rendered as pipe-separated segments above the h1. */
  eyebrowParts?: string[];
  headline: string;
  /** Each line becomes a <span> with display:block. The metaphor sits between h1 and subhead. */
  metaphor?: string[];
  /** Subhead paragraph below the metaphor. */
  sub?: string;
}

const { eyebrowParts, headline, metaphor, sub } = Astro.props;
const hasFigure = Astro.slots.has('figure');
---

<section class="elevation-hero" data-has-figure={hasFigure}>
  <div class="hero-content">
    {eyebrowParts && eyebrowParts.length > 0 && (
      <p class="hero-eyebrow">
        {eyebrowParts.map((part, i) => (
          <>
            {i > 0 && <span class="pipe">·</span>}
            {part}
          </>
        ))}
      </p>
    )}
    <h1>{headline}</h1>
    {metaphor && metaphor.length > 0 && (
      <p class="hero-metaphor">
        {metaphor.map((line) => <span>{line}</span>)}
      </p>
    )}
    {sub && <p class="hero-sub">{sub}</p>}
    {Astro.slots.has('default') && <div class="hero-ctas"><slot /></div>}
  </div>
  {hasFigure && <slot name="figure" />}
</section>

<style>
  .elevation-hero {
    position: relative;
    padding: var(--el-hero-pad-top) 0 var(--el-hero-pad-bot);
  }
  .hero-content {
    min-width: 0;
    max-width: 50rem;
    position: relative;
    z-index: 2;
  }
  .hero-eyebrow {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    color: var(--el-accent);
    margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 3rem);
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .hero-eyebrow .pipe {
    color: var(--el-text-quiet);
    margin: 0 0.7rem;
    font-weight: 400;
  }
  .elevation-hero :global(h1) {
    font-family: var(--el-display);
    font-size: var(--el-h1);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    margin-bottom: clamp(1.25rem, 1rem + 1.5vw, 2.5rem);
    color: var(--el-text);
    /* prevent ultra-long words from overflowing the viewport */
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-metaphor {
    font-family: var(--el-display);
    font-size: var(--el-metaphor);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    color: var(--el-accent);
    margin-top: -0.5rem;
    margin-bottom: clamp(1.25rem, 1rem + 1.5vw, 2.5rem);
    max-width: 30ch;
  }
  .hero-metaphor :global(span) { display: block; }
  .hero-sub {
    font-family: var(--el-body);
    font-size: var(--el-sub);
    line-height: 1.5;
    color: var(--el-text-soft);
    max-width: 48ch;
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.5rem);
  }
  .hero-ctas {
    display: flex;
    gap: clamp(1.25rem, 0.75rem + 2vw, 2.5rem);
    flex-wrap: wrap;
    align-items: center;
  }
  /* CTA styles - global so links inside the slot pick them up */
  :global(.cta) {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 14px;
    text-decoration: none;
    transition: color 0.2s;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  :global(.cta-primary) {
    color: var(--el-accent);
    border-bottom: 1px solid var(--el-accent);
    padding-bottom: 0.5rem;
    position: relative;
  }
  :global(.cta-primary:hover) {
    color: var(--el-text);
    border-color: var(--el-text);
  }
  :global(.cta-primary::before) {
    content: '\261E';
    position: absolute;
    left: -1.5em;
    top: -0.15em;
    font-size: 1.4em;
    line-height: 1;
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s ease;
    transform: translateX(0.4em);
    pointer-events: none;
    color: var(--el-accent);
  }
  :global(.cta-primary:hover::before) {
    opacity: 1;
    transform: translateX(0);
  }
  :global(.cta-secondary) { color: var(--el-text-soft); }
  :global(.cta-secondary:hover) { color: var(--el-accent); }
</style>
