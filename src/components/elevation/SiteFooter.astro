---
/**
 * SiteFooter - elevation register bottom of page
 *
 * Newsletter signup on the left, footer-meta links + version line on the
 * right, astrolabe quarter-arc in the corner. Verbatim from j.html.
 */
import Astrolabe from './Astrolabe.astro';

interface FooterLink { href: string; label: string; }
interface Props {
  /** Override the version line at the bottom. */
  versionLine?: string;
  /** Override the footer-meta link row. */
  metaLinks?: FooterLink[];
  /** Override the newsletter section copy. */
  newsletterLabel?: string;
  newsletterHeading?: string;
  newsletterBlurb?: string;
  /** Show the astrolabe corner. Default true. */
  astrolabe?: boolean;
}

const {
  versionLine = "Evoked · The Agentic Standard · Vol. 01 · 2026",
  metaLinks = [
    { href: "/principles", label: "Principles" },
    { href: "/registry",   label: "Registry" },
    { href: "/engage",     label: "Working Group" },
    { href: "/legal/terms", label: "License" },
    { href: "/specs",      label: "Spec" },
  ],
  newsletterLabel   = "If you want to stay in the conversation",
  newsletterHeading = "Letters about the Standard, the practice, and what we are building.",
  newsletterBlurb   = "Sent when there is something worth sending. Not often.",
  astrolabe         = true,
} = Astro.props;
---

<footer class="site">
  <div class="newsletter">
    <p class="newsletter-label">{newsletterLabel}</p>
    <h3>{newsletterHeading}</h3>
    <p>{newsletterBlurb}</p>
    <form data-evoke-newsletter novalidate>
      <input type="email" placeholder="your.email@example.com" required aria-label="Email address" />
      <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <button type="submit">Subscribe</button>
    </form>
    <p class="newsletter-status hidden" aria-live="polite"></p>
  </div>
  <div class="footer-meta">
    <div class="footer-meta-row">
      {metaLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    <div class="footer-meta-quiet">{versionLine}</div>
  </div>
  {astrolabe && <Astrolabe />}
</footer>

<script>
  // SiteFooter newsletter form - wired to /api/newsletter/subscribe (beehiiv backend).
  // Uses the same challenge-token-then-subscribe pattern as the writing/ pages.
  // Re-attaches after each ClientRouter navigation since the footer re-renders.
  function attachFooterNewsletterForms() {
    document.querySelectorAll<HTMLFormElement>('form[data-evoke-newsletter]').forEach((form) => {
      if (form.dataset.newsletterWired === 'true') return;
      form.dataset.newsletterWired = 'true';

      const emailInput = form.querySelector<HTMLInputElement>('input[type="email"]');
      const hpInput = form.querySelector<HTMLInputElement>('input[name="website"]');
      const button = form.querySelector<HTMLButtonElement>('button');
      const status = form.parentElement?.querySelector<HTMLParagraphElement>('.newsletter-status');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!emailInput || !button) return;
        const email = emailInput.value.trim();
        if (!email) return;

        // Honeypot: bot filled the hidden field - silent success
        if (hpInput?.value) {
          button.textContent = 'Thank you ✓';
          emailInput.value = '';
          return;
        }

        const originalText = button.textContent || 'Subscribe';
        button.disabled = true;
        button.textContent = 'Subscribing...';
        if (status) {
          status.textContent = '';
          status.classList.remove('error', 'success', 'hidden');
        }

        const showError = (msg: string) => {
          button.textContent = originalText;
          button.disabled = false;
          if (status) {
            status.textContent = msg;
            status.classList.remove('success', 'hidden');
            status.classList.add('error');
          }
        };

        try {
          // 1. Fetch challenge token (HMAC-signed by server)
          const cRes = await fetch('/api/newsletter/challenge');
          if (!cRes.ok) {
            showError('Something went wrong. Try again.');
            return;
          }
          const { token, ts } = await cRes.json();

          // 2. Submit subscribe with token + honeypot
          const sRes = await fetch('/api/newsletter/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, token, ts, hp: hpInput?.value || '', source: 'website-footer' }),
          });

          if (sRes.ok) {
            button.textContent = 'Thank you ✓';
            emailInput.value = '';
            if (status) {
              status.textContent = 'You are in. Welcome.';
              status.classList.remove('error', 'hidden');
              status.classList.add('success');
            }
          } else {
            const data = await sRes.json().catch(() => ({} as { error?: string }));
            showError(data?.error || 'Something went wrong. Try again.');
          }
        } catch {
          showError('Something went wrong. Try again.');
        }
      });
    });
  }
  attachFooterNewsletterForms();
  document.addEventListener('astro:after-swap', attachFooterNewsletterForms);
</script>

<style>
  footer.site {
    position: relative;
    max-width: var(--el-content-max);
    margin: 0 auto;
    padding: clamp(3rem, 2rem + 3vw, 5rem) var(--el-content-pad) clamp(2rem, 1.5rem + 1.5vw, 3rem);
    border-top: 1px solid var(--el-rule);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 2rem + 2.5vw, 5rem);
  }
  @media (max-width: 900px) { footer.site { grid-template-columns: 1fr; gap: 2.5rem; } }
  .newsletter-label {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    color: var(--el-accent);
    margin-bottom: 1.25rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .newsletter h3 {
    font-family: var(--el-display);
    font-size: 18px;
    font-weight: 400;
    margin-bottom: 1.25rem;
    line-height: 1.3;
    color: var(--el-text);
    letter-spacing: 0.025em;
    text-transform: uppercase;
  }
  .newsletter p {
    font-family: var(--el-body);
    color: var(--el-text-soft);
    margin-bottom: 2rem;
    font-size: 18px;
    line-height: 1.5;
    max-width: 42ch;
  }
  .newsletter form {
    display: flex;
    gap: 0.5rem;
    max-width: 440px;
    border-bottom: 1px solid var(--el-text);
    padding-bottom: 0.5rem;
  }
  .newsletter input {
    flex: 1;
    padding: 0.4rem 0;
    background: transparent;
    border: none;
    font-family: var(--el-body);
    font-size: 18px;
    color: var(--el-text);
  }
  .newsletter input::placeholder { color: var(--el-text-quiet); }
  .newsletter input:focus { outline: none; }
  .newsletter button {
    padding: 0.4rem 0;
    background: transparent;
    color: var(--el-accent);
    border: none;
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    cursor: pointer;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .newsletter button:hover { color: var(--el-text); }
  .newsletter button:disabled { opacity: 0.6; cursor: wait; }

  /* honeypot field - visually + semantically hidden but submittable */
  .hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    z-index: -1;
  }

  /* status message rendered below the form (success or error) */
  .newsletter-status {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 0.85rem;
    min-height: 1.2em;
    color: var(--el-text-quiet);
  }
  .newsletter-status.hidden { display: none; }
  .newsletter-status.success { color: var(--el-accent); }
  .newsletter-status.error { color: #c44; }
  .footer-meta {
    align-self: end;
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    color: var(--el-text-quiet);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding-right: 5rem; /* leave room for astrolabe in corner on desktop */
  }
  @media (max-width: 900px) {
    .footer-meta { padding-right: 0; padding-bottom: 5rem; }
  }
  .footer-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2.25rem;
    margin-bottom: 1.5rem;
  }
  .footer-meta a { color: var(--el-text-soft); text-decoration: none; }
  .footer-meta a:hover { color: var(--el-accent); }
  .footer-meta-quiet { color: var(--el-text-quiet); letter-spacing: 0.22em; }
</style>
