---
---

<div class="fit-assessment">
  <form id="fit-form" class="fit-form">
    <label for="project-description">
      <h3>Describe your project</h3>
      <p class="label-hint">Include context like: target audience, data handled, technical requirements, and what kind of help you're looking for.</p>
    </label>
    <textarea
      id="project-description"
      name="projectDescription"
      placeholder="We're deploying AI agents for customer support and need help with governance, memory architecture, and specification engineering..."
      rows="6"
    ></textarea>
    <div class="char-count">
      <span id="char-count">0</span> / 5000 characters
    </div>
    <button type="submit" class="btn" id="assess-btn">Assess Fit</button>
  </form>

  <div id="fit-result" class="fit-result hidden">
    <div class="result-header">
      <div class="fit-badge" id="fit-badge">
        <span class="fit-level" id="fit-level">Strong Fit</span>
        <span class="fit-score" id="fit-score">8/10</span>
      </div>
      <p class="fit-summary" id="fit-summary"></p>
    </div>

    <div class="result-sections">
      <div class="result-section strengths">
        <h4>Strengths</h4>
        <ul id="strengths-list"></ul>
      </div>

      <div class="result-section considerations">
        <h4>Considerations</h4>
        <ul id="considerations-list"></ul>
      </div>

      <div class="result-section services">
        <h4>Suggested Services</h4>
        <ul id="services-list"></ul>
      </div>

      <div class="result-section next-step">
        <h4>Next Step</h4>
        <p id="next-step"></p>
      </div>
    </div>

    <div class="result-actions">
      <button type="button" class="btn" id="reset-btn">Assess Another Project</button>
      <a href="mailto:passionevoked@icloud.com?subject=Consulting Inquiry" class="btn btn-primary">Get in Touch</a>
    </div>

    <div id="fit-email-capture" class="fit-email-capture">
      <hr class="capture-divider" />

      <div id="email-form-area">
        <p class="email-capture-lead">Want a copy of your assessment with relevant next steps? Enter your email — nothing else happens unless you want it to.</p>
        <form id="email-form" class="email-form" novalidate>
          <input type="text" id="email-hp" name="hp" style="display: none;" tabindex="-1" autocomplete="off" />
          <div class="email-form-row">
            <input
              type="email"
              id="email-input"
              placeholder="your@email.com"
              autocomplete="email"
            />
            <button type="submit" id="email-submit-btn" class="btn">[CTA TEXT]</button>
          </div>
          <label class="newsletter-opt-in">
            <input type="checkbox" id="newsletter-checkbox" />
            <span>Also hear from us occasionally about sovereignty-honoring AI design</span>
          </label>
        </form>
      </div>

      <div id="email-success" class="email-feedback hidden">
        <p>[NEEDS FLEET REVIEW — success message]</p>
      </div>

      <div id="email-error" class="email-feedback email-feedback-error hidden">
        <p id="email-error-msg"></p>
        <button type="button" id="email-retry" class="btn-link">Try again</button>
      </div>

      <div id="email-sending" class="email-feedback hidden">
        <p>[NEEDS FLEET REVIEW — sending state]</p>
      </div>
    </div>
  </div>

  <div id="fit-loading" class="fit-loading hidden">
    <div class="loading-spinner"></div>
    <p>Assessing project fit...</p>
  </div>

  <div id="fit-error" class="fit-error hidden">
    <p id="error-message">Something went wrong. Please try again.</p>
    <button type="button" class="btn" id="retry-btn">Try Again</button>
  </div>
</div>

<script>
  interface FitAssessment {
    fitLevel: 'strong' | 'moderate' | 'limited' | 'not-recommended';
    score: number;
    summary: string;
    strengths: string[];
    considerations: string[];
    suggestedServices: string[];
    nextStep: string;
  }

  const form = document.getElementById('fit-form') as HTMLFormElement;
  const textarea = document.getElementById('project-description') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count') as HTMLSpanElement;
  const assessBtn = document.getElementById('assess-btn') as HTMLButtonElement;
  const resultDiv = document.getElementById('fit-result') as HTMLDivElement;
  const loadingDiv = document.getElementById('fit-loading') as HTMLDivElement;
  const errorDiv = document.getElementById('fit-error') as HTMLDivElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;

  // Email capture elements
  const emailFormArea = document.getElementById('email-form-area') as HTMLDivElement;
  const emailForm = document.getElementById('email-form') as HTMLFormElement;
  const emailInput = document.getElementById('email-input') as HTMLInputElement;
  const emailHp = document.getElementById('email-hp') as HTMLInputElement;
  const newsletterCheckbox = document.getElementById('newsletter-checkbox') as HTMLInputElement;
  const emailSuccess = document.getElementById('email-success') as HTMLDivElement;
  const emailErrorDiv = document.getElementById('email-error') as HTMLDivElement;
  const emailErrorMsg = document.getElementById('email-error-msg') as HTMLParagraphElement;
  const emailRetry = document.getElementById('email-retry') as HTMLButtonElement;
  const emailSending = document.getElementById('email-sending') as HTMLDivElement;

  // Holds the last completed assessment for the email form to reference
  let currentAssessment: FitAssessment | null = null;

  // Character count
  textarea.addEventListener('input', () => {
    charCount.textContent = String(textarea.value.length);
  });

  function showForm() {
    form.classList.remove('hidden');
    resultDiv.classList.add('hidden');
    loadingDiv.classList.add('hidden');
    errorDiv.classList.add('hidden');
    currentAssessment = null;
    // Reset email capture
    emailFormArea.classList.remove('hidden');
    emailSuccess.classList.add('hidden');
    emailErrorDiv.classList.add('hidden');
    emailSending.classList.add('hidden');
    emailInput.value = '';
    newsletterCheckbox.checked = false;
  }

  function showLoading() {
    form.classList.add('hidden');
    resultDiv.classList.add('hidden');
    loadingDiv.classList.remove('hidden');
    errorDiv.classList.add('hidden');
  }

  function showResult(assessment: FitAssessment) {
    currentAssessment = assessment;
    form.classList.add('hidden');
    loadingDiv.classList.add('hidden');
    errorDiv.classList.add('hidden');
    resultDiv.classList.remove('hidden');

    // Update badge
    const badge = document.getElementById('fit-badge') as HTMLDivElement;
    badge.className = `fit-badge ${assessment.fitLevel}`;

    const levelText = {
      strong: 'Strong Fit',
      moderate: 'Moderate Fit',
      limited: 'Limited Fit',
      'not-recommended': 'Not Recommended',
    };
    (document.getElementById('fit-level') as HTMLSpanElement).textContent = levelText[assessment.fitLevel];
    (document.getElementById('fit-score') as HTMLSpanElement).textContent = `${assessment.score}/10`;
    (document.getElementById('fit-summary') as HTMLParagraphElement).textContent = assessment.summary;

    // Populate lists
    const strengthsList = document.getElementById('strengths-list') as HTMLUListElement;
    strengthsList.replaceChildren(...assessment.strengths.map(s => { const li = document.createElement('li'); li.textContent = s; return li; }));

    const considerationsList = document.getElementById('considerations-list') as HTMLUListElement;
    considerationsList.replaceChildren(...assessment.considerations.map(c => { const li = document.createElement('li'); li.textContent = c; return li; }));

    const servicesList = document.getElementById('services-list') as HTMLUListElement;
    servicesList.replaceChildren(...assessment.suggestedServices.map(s => { const li = document.createElement('li'); li.textContent = s; return li; }));

    (document.getElementById('next-step') as HTMLParagraphElement).textContent = assessment.nextStep;
  }

  function showError(message: string) {
    form.classList.add('hidden');
    loadingDiv.classList.add('hidden');
    resultDiv.classList.add('hidden');
    errorDiv.classList.remove('hidden');
    (document.getElementById('error-message') as HTMLParagraphElement).textContent = message;
  }

  async function assessFit(projectDescription: string) {
    showLoading();

    try {
      // Fetch challenge token
      const c = await fetch('/api/form/challenge');
      if (!c.ok) throw new Error('failed');
      const { token, ts } = await c.json();

      const response = await fetch('/api/assess-fit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ projectDescription, token, ts, hp: '' }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Failed to assess fit');
      }

      showResult(data as FitAssessment);
    } catch (error) {
      showError(error instanceof Error ? error.message : 'Something went wrong. Please try again.');
    }
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const description = textarea.value.trim();
    if (description) {
      assessFit(description);
    }
  });

  resetBtn.addEventListener('click', () => {
    textarea.value = '';
    charCount.textContent = '0';
    showForm();
  });

  retryBtn.addEventListener('click', () => {
    showForm();
  });

  // --- Email capture ---

  function setEmailState(state: 'form' | 'sending' | 'success' | 'error') {
    emailFormArea.classList.toggle('hidden', state !== 'form');
    emailSending.classList.toggle('hidden', state !== 'sending');
    emailSuccess.classList.toggle('hidden', state !== 'success');
    emailErrorDiv.classList.toggle('hidden', state !== 'error');
  }

  async function submitEmailCapture(email: string, subscribeNewsletter: boolean) {
    if (!currentAssessment) return;

    setEmailState('sending');

    try {
      const c = await fetch('/api/form/challenge');
      if (!c.ok) throw new Error('failed');
      const { token, ts } = await c.json();

      const response = await fetch('/api/fit-followup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          fitLevel: currentAssessment.fitLevel,
          score: currentAssessment.score,
          strengths: currentAssessment.strengths,
          considerations: currentAssessment.considerations,
          suggestedServices: currentAssessment.suggestedServices,
          subscribeNewsletter,
          token,
          ts,
          hp: emailHp.value,
        }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Something went wrong. Please try again.');
      }

      setEmailState('success');
    } catch (err) {
      emailErrorMsg.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      setEmailState('error');
    }
  }

  emailForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email || !email.includes('@')) {
      emailErrorMsg.textContent = 'Please enter a valid email address.';
      setEmailState('error');
      return;
    }
    submitEmailCapture(email, newsletterCheckbox.checked);
  });

  emailRetry.addEventListener('click', () => {
    setEmailState('form');
  });
</script>

<style>
  .fit-assessment {
    max-width: 700px;
    margin: 0 auto;
  }

  .fit-form label h3 {
    margin-bottom: var(--space-xs);
  }

  .label-hint {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .fit-form textarea {
    width: 100%;
    padding: var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    font-family: var(--font-body);
    line-height: 1.6;
    resize: vertical;
  }

  .fit-form textarea:focus {
    outline: none;
    border-color: var(--border-accent);
  }

  .fit-form textarea::placeholder {
    color: var(--text-muted);
  }

  .char-count {
    text-align: right;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .hidden {
    display: none !important;
  }

  /* Results */
  .fit-result {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: var(--space-md);
  }

  .result-header {
    text-align: center;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
  }

  .fit-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    border-radius: 100px;
    margin-bottom: var(--space-sm);
  }

  .fit-badge.strong {
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
  .fit-badge.strong .fit-level { color: #22c55e; }

  .fit-badge.moderate {
    background: rgba(196, 167, 125, 0.15);
    border: 1px solid rgba(196, 167, 125, 0.3);
  }
  .fit-badge.moderate .fit-level { color: var(--accent-warm); }

  .fit-badge.limited {
    background: rgba(234, 179, 8, 0.15);
    border: 1px solid rgba(234, 179, 8, 0.3);
  }
  .fit-badge.limited .fit-level { color: #eab308; }

  .fit-badge.not-recommended {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
  .fit-badge.not-recommended .fit-level { color: #ef4444; }

  .fit-level {
    font-weight: 500;
  }

  .fit-score {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .fit-summary {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--text-primary);
    margin: 0;
  }

  .result-sections {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .result-section h4 {
    color: var(--accent-warm);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
    font-family: var(--font-body);
  }

  .result-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .result-section li {
    padding: var(--space-xs) 0;
    padding-left: var(--space-md);
    border-left: 2px solid var(--border-subtle);
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .result-section.strengths li {
    border-left-color: rgba(34, 197, 94, 0.5);
  }

  .result-section.considerations li {
    border-left-color: rgba(234, 179, 8, 0.5);
  }

  .result-section p {
    color: var(--text-secondary);
    margin: 0;
  }

  .result-actions {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    padding-top: var(--space-md);
    border-top: 1px solid var(--border-subtle);
  }

  .btn-primary {
    background: var(--accent-warm);
    color: var(--bg-deep);
  }

  .btn-primary:hover {
    background: var(--accent-glow);
    color: var(--bg-deep);
  }

  /* Loading */
  .fit-loading {
    text-align: center;
    padding: var(--space-xl) var(--space-md);
  }

  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border-subtle);
    border-top-color: var(--accent-warm);
    border-radius: 50%;
    margin: 0 auto var(--space-md);
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .fit-loading p {
    color: var(--text-muted);
  }

  /* Email capture */
  .fit-email-capture {
    margin-top: var(--space-md);
  }

  .capture-divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 0 0 var(--space-md);
  }

  .email-capture-lead {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: var(--space-sm);
  }

  .email-form-row {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .email-form-row input[type="email"] {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 1rem;
    font-family: var(--font-body);
  }

  .email-form-row input[type="email"]:focus {
    outline: none;
    border-color: var(--border-accent);
  }

  .newsletter-opt-in {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    font-size: 0.875rem;
    color: var(--text-muted);
    cursor: pointer;
  }

  .newsletter-opt-in input[type="checkbox"] {
    margin-top: 2px;
    flex-shrink: 0;
  }

  .email-feedback {
    font-size: 0.95rem;
    color: var(--text-secondary);
    padding: var(--space-sm) 0;
  }

  .email-feedback-error {
    color: #ef4444;
  }

  .btn-link {
    background: none;
    border: none;
    padding: 0;
    color: var(--text-muted);
    font-size: 0.875rem;
    cursor: pointer;
    text-decoration: underline;
    font-family: var(--font-body);
  }

  .btn-link:hover {
    color: var(--text-primary);
  }

  /* Error */
  .fit-error {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 12px;
  }

  .fit-error p {
    color: #ef4444;
    margin-bottom: var(--space-md);
  }
</style>
