---
import ElevationLayout from '../layouts/ElevationLayout.astro';
import Hero from '../components/elevation/Hero.astro';
import OrionFigure from '../components/elevation/OrionFigure.astro';
import Section from '../components/elevation/Section.astro';
---

<ElevationLayout
  title="The Agentic Standard"
  description="Identity, scope, and signed evidence for AI agents that work with the humans behind them. Built in public, shared by license, kept in common."
  siblingActive={true}
>
  <Hero
    eyebrowParts={["Vol. 01"]}
    headline="The Agentic Standard."
    metaphor={["Credentials prove who.", "Provenance proves what survived."]}
    sub="Most agent systems cannot tell you whose character is operating. We measure character under pressure. Identity, scope, and signed evidence for AI agents that work with the humans behind them. Built in public, shared by license, kept in common."
  >
    <a class="cta cta-primary" href="/score">Take the free test</a>
    <a class="cta cta-secondary" href="/patents">See the patents &rarr;</a>
    <OrionFigure slot="figure" tradition="bayer" citationVisibility="low-bright" />
  </Hero>

  <Section
    id="doorway"
    marker="FIG · I"
    label="Find your doorway"
    heading="Five entrances. One practice."
  >
    <div class="routing-grid">
      <a href="/build-with-us" class="route-card route-primary">
        <p class="route-audience">You have an idea for something that serves a family, a community, a group that matters - and you refuse to build it the extractive way.</p>
        <p class="route-action">Sovereignty-honoring software for families, communities, and individuals.</p>
        <span class="route-cta">Tell us your idea &rarr;</span>
      </a>
      <a href="/coaching" class="route-card">
        <p class="route-audience">The ground shifted. Maybe it's AI changing your industry. Maybe a career that doesn't fit anymore. Maybe something deeper. You're not broken - you're in transition.</p>
        <p class="route-action">Depth work that honors where you've been while orienting toward where you're going.</p>
        <span class="route-cta">Learn about coaching &rarr;</span>
      </a>
      <a href="/engage" class="route-card">
        <p class="route-audience">You shipped fast. It works. But you know there are gaps - governance, safety, boundaries your agents should have but don't yet.</p>
        <p class="route-action">Governance audits, specification sprints, trust architecture builds.</p>
        <span class="route-cta">See the engagement window &rarr;</span>
      </a>
      <a href="/engage" class="route-card">
        <p class="route-audience">Your team built the agents. Now someone is asking how they make decisions - and nobody has a good answer.</p>
        <p class="route-action">Structured reviews of agent behavioral governance - identity, memory, restraint, voice, drift.</p>
        <span class="route-cta">See enterprise governance &rarr;</span>
      </a>
      <a href="/registry" class="route-card">
        <p class="route-audience">You believe AI agents should be able to prove they're governed - and that the standard should be open, not owned.</p>
        <p class="route-action">Voluntary, open standard for agent behavioral governance. Registration is free.</p>
        <span class="route-cta">See the registry &rarr;</span>
      </a>
    </div>
  </Section>

  <Section
    id="proof"
    marker="FIG · II"
    label="The demonstration"
    heading="We built this for ourselves first."
  >
    <div class="proof">
      <p class="proof-lead">142 agents. Their own identities. Their own right to refuse.</p>
      <p class="proof-detail">Governance schema adopted by the Agent Passport System (2,300+ tests, SDK v1.36). <a href="/patents">Two patents filed</a>. The measurement methodology is ours.</p>
    </div>
  </Section>

  <Section
    id="we-build"
    marker="FIG · III"
    label="The product we live by"
    heading="And we ship it."
  >
    <div class="we-build">
      <p class="we-build-detail">A family meal-planning app where the table is the table. What happens around it belongs to the family - not to the system measuring it. Built under our own 142-agent governance framework. COPPA-compliant by architecture, not by retrofit.</p>
      <a href="/kitchen-table/" class="cta cta-secondary">See The Kitchen Table &rarr;</a>
    </div>
  </Section>

  <Section
    id="ladder"
    marker="FIG · IV"
    label="The ladder"
    heading="Start where you are."
  >
    <p class="lede">The same practice, at your tier.</p>
    <div class="ladder-grid">
      <a href="/score" class="ladder-step">
        <span class="ladder-price">Free</span>
        <span class="ladder-name">Take the score</span>
        <span class="ladder-desc">Sovereignty Score, CLI scan, diagnostic, GitHub patterns</span>
      </a>
      <a href="/products/governance-templates-guided" class="ladder-step">
        <span class="ladder-price">$5</span>
        <span class="ladder-name">Start closing gaps</span>
        <span class="ladder-desc">Five governance templates with worked examples from a real system</span>
      </a>
      <a href="/products/governance-implementation-guide" class="ladder-step">
        <span class="ladder-price">$9.99</span>
        <span class="ladder-name">Add governance to what you built</span>
        <span class="ladder-desc">Framework-specific guide for CrewAI, LangGraph, and Pydantic AI</span>
      </a>
      <a href="/products" class="ladder-step">
        <span class="ladder-price">$49+</span>
        <span class="ladder-name">Go deep on one dimension</span>
        <span class="ladder-desc">Trust architecture, restraint specs, memory governance, voice design</span>
      </a>
      <a href="/products/level-6-governance-toolkit" class="ladder-step">
        <span class="ladder-price">$99</span>
        <span class="ladder-name">Audit the whole system</span>
        <span class="ladder-desc">Three instruments. 60-point scorecard. The Level 6 Governance Toolkit.</span>
      </a>
      <a href="/consulting" class="ladder-step">
        <span class="ladder-price">$5K+</span>
        <span class="ladder-name">We do it with you</span>
        <span class="ladder-desc">Hands-on governance audit in your codebase, with your team</span>
      </a>
    </div>
  </Section>

  <Section
    id="two-absence"
    marker="FIG · V"
    label="What is missing"
    heading="Two questions most teams cannot yet answer."
  >
    <div class="two-absence">
      <p class="two-absence-text">Can your agents participate in their own governance? Can your governance survive a platform change?</p>
      <p class="two-absence-source">Both questions have answers. Most teams cannot articulate either yet. Five frameworks scored. Three principles at zero across all of them. <a href="/score">Score yours.</a></p>
    </div>
  </Section>

  <Section
    id="reading"
    marker="FIG · VI"
    label="Further reading"
    heading="Start reading."
  >
    <div class="reading-grid">
      <a href="/writing/fifteen-frameworks" class="reading-card">
        <span class="reading-label">If you build agents</span>
        <p class="reading-title">Fifteen Frameworks, One Missing Layer</p>
      </a>
      <a href="/writing/adding-governance-to-an-agent-you-already-built" class="reading-card">
        <span class="reading-label">If you want to add governance now</span>
        <p class="reading-title">Adding Governance to an Agent You Already Built</p>
      </a>
      <a href="/writing/relational-fidelity-metrics" class="reading-card">
        <span class="reading-label">If you want the research</span>
        <p class="reading-title">Relational Fidelity Metrics</p>
      </a>
    </div>
  </Section>

  <Section id="note" marker="NOTA · BENE" closing={true}>
    <div class="closing-body">
      <p>If the work reads true, sit with it. If you have a question, write. If you would like to add your voice, the door is open.</p>
      <p>What you read here is the Standard's character - quiet, deliberate, in public. If the form fits the claim, we are in conversation.</p>
      <div class="closing-ctas">
        <a class="cta cta-primary" href="/engage">Write</a>
        <a class="cta cta-secondary" href="/spec">Read the spec &rarr;</a>
      </div>
    </div>
  </Section>
</ElevationLayout>

<style>
  /* === page-level composition styles ===
     Adapted from previous BaseLayout-era index to use --el-* tokens. */

  /* routing-grid (5 audience-route cards) */
  .routing-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  @media (max-width: 800px) { .routing-grid { grid-template-columns: 1fr; gap: 1.5rem; } }

  .route-card {
    padding: 2.25rem 2rem;
    background: rgba(255, 250, 240, 0.35);
    border: 1px solid var(--el-rule);
    box-shadow: var(--el-panel-shadow);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .route-card:hover {
    border-color: var(--el-accent);
    transform: translateY(-2px);
  }
  .route-primary {
    border-color: var(--el-accent);
  }
  .route-audience {
    font-family: var(--el-display);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: 0.015em;
    text-transform: uppercase;
    color: var(--el-text);
    margin: 0;
  }
  .route-action {
    font-family: var(--el-body);
    font-size: 16px;
    color: var(--el-text-soft);
    line-height: 1.55;
    margin: 0;
  }
  .route-cta {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    color: var(--el-accent);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-top: auto;
  }

  /* proof */
  .proof {
    max-width: 60ch;
  }
  .proof-lead {
    font-family: var(--el-display);
    font-size: 22px;
    line-height: 1.35;
    letter-spacing: 0.015em;
    text-transform: uppercase;
    color: var(--el-text);
    margin-bottom: 1.5rem;
  }
  .proof-detail {
    font-family: var(--el-body);
    font-size: 18px;
    color: var(--el-text-soft);
    line-height: 1.6;
  }
  .proof-detail a {
    color: var(--el-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--el-accent);
  }
  .proof-detail a:hover { color: var(--el-text); }

  /* we-build (Kitchen Table proof-of-life) */
  .we-build {
    max-width: 60ch;
  }
  .we-build-detail {
    font-family: var(--el-body);
    font-size: 18px;
    color: var(--el-text-soft);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  /* ladder (6-tier pricing grid) */
  .ladder-grid {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media (max-width: 900px) { .ladder-grid { margin-top: 3rem; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } }
  @media (max-width: 600px) { .ladder-grid { margin-top: 2.5rem; grid-template-columns: 1fr; gap: 1.25rem; } }

  .ladder-step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 2rem 1.75rem;
    border: 1px solid var(--el-rule);
    background: rgba(255, 250, 240, 0.3);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }
  .ladder-step:hover {
    border-color: var(--el-accent);
    transform: translateY(-2px);
  }
  .ladder-price {
    font-family: var(--el-display);
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--el-accent);
  }
  .ladder-name {
    font-family: var(--el-display);
    font-size: 16px;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--el-text);
  }
  .ladder-desc {
    font-family: var(--el-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--el-text-soft);
  }

  /* two-absence (the missing-questions section) */
  .two-absence { max-width: 60ch; }
  .two-absence-text {
    font-family: var(--el-display);
    font-size: 22px;
    line-height: 1.35;
    letter-spacing: 0.015em;
    text-transform: uppercase;
    color: var(--el-text);
    margin-bottom: 1.5rem;
  }
  .two-absence-source {
    font-family: var(--el-body);
    font-size: 18px;
    color: var(--el-text-soft);
    line-height: 1.6;
  }
  .two-absence-source a {
    color: var(--el-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--el-accent);
  }
  .two-absence-source a:hover { color: var(--el-text); }

  /* reading-grid */
  .reading-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }
  .reading-card {
    padding: 2rem 1.75rem;
    background: rgba(255, 250, 240, 0.4);
    border: 1px solid var(--el-rule);
    box-shadow: var(--el-panel-shadow);
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.2s, transform 0.2s;
  }
  .reading-card:hover {
    border-color: var(--el-accent);
    transform: translateY(-2px);
  }
  .reading-label {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-accent);
    display: block;
    margin-bottom: 1rem;
  }
  .reading-title {
    font-family: var(--el-display);
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--el-text);
    margin: 0;
  }

  /* closing-body (NOTA · BENE) */
  .closing-body { max-width: 56ch; }
  .closing-body :global(p) {
    font-family: var(--el-body);
    font-weight: 400;
    font-size: 24px;
    line-height: 1.5;
    color: var(--el-text);
    margin-bottom: 2rem;
    letter-spacing: 0.005em;
  }
  .closing-ctas {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 1rem;
  }
</style>
