---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Erin Stanley - coaching, consulting, and sovereignty-honoring AI products. Depth work for people, ethical governance for technology.">
  <div class="hero">
    <h1 class="fade-in">Welcome.</h1>
    <p class="tagline fade-in">Look around. Something here might be for you.</p>
  </div>

  <section class="container">
    <div class="hearth-text">
      <p>This is a practice of noticing.</p>
      <p>What is already worth protecting?  What deserves better?  What happens when we build from care instead of extraction?</p>
      <p>I work with people through turning points.  I guide organizations to govern their AI with integrity.  I build software that serves families.</p>
      <p>And I refuse to do work that treats people as resources to be optimized.</p>
      <p class="refusal-signal">What I won't build matters as much as what I will.  <a href="/refusals">The six refusals</a> are the foundation on which everything else stands.</p>
    </div>
  </section>

  <section class="container">
    <h2 class="souls-heading">You might be here because...</h2>
    <div class="souls">
      <a href="/work-with-us#creator" class="soul-group">
        <p class="soul-feeling">you want to build something that matters</p>
        <p class="soul-name">You are looking for someone who builds it the way you would.</p>
      </a>

      <a href="/work-with-us#developer" class="soul-group">
        <p class="soul-feeling">you're building agents and want to build them right</p>
        <p class="soul-name">Free governance patterns, open specs, and implementation guides. <span class="quick-link">Start free on GitHub &rarr;</span></p>
      </a>

      <a href="/work-with-us#executive" class="soul-group">
        <p class="soul-feeling">your organization is deploying AI and you need governance you can trust</p>
        <p class="soul-name">Assessment tools, EU AI Act mapping, and governance audits. <span class="quick-link">Take the free diagnostic &rarr;</span></p>
      </a>

      <a href="/coaching" class="soul-group">
        <p class="soul-feeling">something in your life is asking for attention</p>
        <p class="soul-name">A turning point, a relationship, a direction. Depth work, not quick fixes.</p>
      </a>

      <a href="/writing" class="soul-group">
        <p class="soul-feeling">you noticed something here and want to understand</p>
        <p class="soul-name">Sovereignty, restraint, and what it means to build without extracting.</p>
      </a>

      <a href="/about" class="soul-group">
        <p class="soul-feeling">you don't know why you're here yet</p>
        <p class="soul-name">that's welcome too. Look around. Stay as long as it's useful.</p>
      </a>
    </div>
  </section>

  <section class="container">
    <div class="quick-starts">
      <h2 class="quick-starts-heading">Start here. Free.</h2>
      <div class="quick-starts-grid">
        <a href="https://github.com/lowkey-divine/agent-governance-starter-kit" target="_blank" rel="noopener" class="quick-start-card">
          <span class="quick-start-label">Developer</span>
          <p class="quick-start-title">Free governance patterns for AI agents</p>
          <p class="quick-start-desc">Templates and code examples from a 142-agent production system. CrewAI, LangGraph, Pydantic AI.</p>
        </a>
        <a href="/diagnostic" class="quick-start-card">
          <span class="quick-start-label">Executive</span>
          <p class="quick-start-title">Is your AI governance real? Find out in 5 minutes.</p>
          <p class="quick-start-desc">Five questions about your agent system. Scored assessment with concrete next steps.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="newsletter-card">
      <h2>Stay in the conversation.</h2>
      <p>Sovereignty-honoring design, ethical AI, and building things that matter.</p>
      <form id="newsletter-form" class="newsletter-form">
        <div class="form-row">
          <input type="email" id="newsletter-email" name="email" placeholder="Your email" required aria-label="Email address" />
          <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" class="hp-field" />
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </div>
        <p id="newsletter-status" class="newsletter-status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const status = document.getElementById('newsletter-status') as HTMLParagraphElement;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
  const hpInput = form.querySelector('input[name="website"]') as HTMLInputElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    if (hpInput.value) {
      status.textContent = 'You are in. Welcome.';
      status.className = 'newsletter-status success';
      emailInput.value = '';
      return;
    }

    status.textContent = '';
    const button = form.querySelector('button') as HTMLButtonElement;
    button.disabled = true;
    button.textContent = 'Subscribing...';

    try {
      const c = await fetch('/api/newsletter/challenge');
      if (!c.ok) throw new Error('failed');
      const { token, ts } = await c.json();

      const res = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, token, ts, hp: hpInput.value }),
      });

      if (res.ok) {
        status.textContent = 'You are in. Welcome.';
        status.className = 'newsletter-status success';
        emailInput.value = '';
      } else {
        const data = await res.json();
        status.textContent = data.error || 'Something went wrong. Try again.';
        status.className = 'newsletter-status error';
      }
    } catch {
      status.textContent = 'Something went wrong. Try again.';
      status.className = 'newsletter-status error';
    } finally {
      button.disabled = false;
      button.textContent = 'Subscribe';
    }
  });
</script>

<style>
  .identity {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-top: var(--space-sm);
  }

  .hearth-text {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .hearth-text p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }

  .hearth-text .refusal-signal {
    color: var(--text-primary);
    font-style: italic;
  }

  .hearth-text .refusal-signal a {
    color: var(--accent-warm);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-subtle);
    transition: border-color var(--transition-smooth);
  }

  .hearth-text .refusal-signal a:hover {
    border-color: var(--accent-warm);
  }

  .souls-heading {
    text-align: center;
    font-size: 1.6rem;
    margin-bottom: var(--space-md);
  }

  .souls {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .soul-group {
    padding: var(--space-md);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    transition: border-color var(--transition-smooth);
    text-decoration: none;
    display: block;
  }

  .soul-group:hover {
    border-color: var(--border-accent);
  }

  .soul-feeling {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--accent-warm);
    margin-bottom: var(--space-xs);
    line-height: 1.4;
  }

  .soul-name {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .quick-link {
    display: block;
    margin-top: var(--space-xs);
    color: var(--accent-warm);
    font-size: 0.85rem;
    font-style: normal;
  }

  .quick-starts {
    text-align: center;
  }

  .quick-starts-heading {
    font-size: 1.4rem;
    margin-bottom: var(--space-md);
  }

  .quick-starts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
    max-width: 700px;
    margin: 0 auto;
  }

  .quick-start-card {
    padding: var(--space-md);
    border: 2px solid var(--accent-subtle);
    border-radius: 8px;
    transition: border-color var(--transition-smooth);
    text-decoration: none;
    display: block;
    text-align: left;
  }

  .quick-start-card:hover {
    border-color: var(--accent-warm);
  }

  .quick-start-label {
    display: inline-block;
    background: var(--accent-subtle);
    color: var(--accent-warm);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: var(--space-xs);
  }

  .quick-start-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
    line-height: 1.4;
  }

  .quick-start-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .newsletter-card {
    max-width: 540px;
    margin: var(--space-lg) auto 0;
    text-align: center;
  }

  .newsletter-card h2 {
    margin-bottom: var(--space-xs);
  }

  .newsletter-card > p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }

  .form-row {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
  }

  .form-row input[type="email"] {
    flex: 1;
    max-width: 300px;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    background: transparent;
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.95rem;
  }

  .form-row input[type="email"]:focus {
    outline: none;
    border-color: var(--accent-warm);
  }

  .form-row input[type="email"]::placeholder {
    color: var(--text-muted);
  }

  .btn-primary {
    background: var(--accent-warm);
    color: var(--bg-deep);
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--accent-glow);
    color: var(--bg-deep);
  }

  .newsletter-status {
    font-size: 0.85rem;
    margin-top: var(--space-sm);
    min-height: 1.2em;
  }

  .newsletter-status.success {
    color: var(--accent-warm);
  }

  .newsletter-status.error {
    color: #e57373;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    z-index: -1;
  }

  @media (max-width: 480px) {
    .form-row {
      flex-direction: column;
      align-items: stretch;
    }

    .form-row input[type="email"] {
      max-width: none;
    }
  }
</style>
