---
import BaseLayout from '../layouts/BaseLayout.astro';

const badges = [
  {
    label: 'agent-governance',
    message: 'defined',
    product: '/products/agent-governance-starter-kit',
    productName: 'Agent Governance Starter Kit',
    description: 'This project has a governance framework - charter, boundaries, drift thresholds, and accountability.',
  },
  {
    label: 'restraint-spec',
    message: 'defined',
    product: '/products/agent-restraint-specification',
    productName: 'Agent Restraint Specification',
    description: 'This project specifies what its agents refuse to do - refusal categories, fail modes, and adversarial testing.',
  },
  {
    label: 'sovereignty',
    message: 'assessed',
    product: '/products/sovereignty-assessment-toolkit',
    productName: 'Sovereignty Assessment Toolkit',
    description: 'This project has been audited against a 47-point sovereignty assessment across 7 domains.',
  },
  {
    label: 'agent-voice',
    message: 'designed',
    product: '/products/agent-voice-architecture-guide',
    productName: 'Agent Voice Architecture Guide',
    description: 'This project has a voice architecture - designed to respect people, not manipulate them.',
  },
  {
    label: 'agent-memory',
    message: 'governed',
    product: '/products/agent-memory-architecture-guide',
    productName: 'Agent Memory Architecture Guide',
    description: 'This project governs what its agents remember, what they forget, and who decides.',
  },
  {
    label: 'trust-architecture',
    message: 'complete',
    product: '/products/trust-architecture-complete',
    productName: 'Trust Architecture Complete',
    description: 'This project implements the full trust architecture - identity, voice, governance, and restraint.',
  },
];

function shieldUrl(label: string, message: string) {
  return `https://img.shields.io/badge/${label.replace(/-/g, '--')}-${message}-c4a77d`;
}

function badgeMarkdown(label: string, message: string) {
  const img = shieldUrl(label, message);
  return `[![${label}: ${message}](${img})](https://evoked.dev/badges)`;
}
---

<BaseLayout title="Governance Badges" description="Open standard README badges for AI agent governance. Signal your project's governance posture. Free to adopt.">
  <div class="hero-compact">
    <p class="discipline-badge">Open Standard</p>
    <h1>Governance Badges</h1>
    <p class="tagline">Signal your project's governance posture. Free to adopt.</p>
  </div>

  <section class="container">
    <p class="lead">
      Every repo signals its license. Its build status. Its test coverage.<br />
      None of them signal whether the agents inside have been told what to refuse.
    </p>
    <p class="lead-sub">
      These badges change that. Add them to your README. Link back here. That's it.
    </p>
  </section>

  <section class="container">
    <h2>The Badges</h2>

    {badges.map((badge) => (
      <div class="badge-card">
        <div class="badge-preview">
          <img src={shieldUrl(badge.label, badge.message)} alt={`${badge.label}: ${badge.message}`} height="20" />
        </div>
        <p class="badge-description">{badge.description}</p>
        <div class="badge-snippet">
          <p class="snippet-label">Markdown</p>
          <code>{badgeMarkdown(badge.label, badge.message)}</code>
        </div>
        <p class="badge-link">
          Framework: <a href={badge.product}>{badge.productName}</a> - $49
        </p>
      </div>
    ))}
  </section>

  <section class="container">
    <h2>How It Works</h2>
    <div class="steps">
      <div class="step">
        <span class="step-number">1</span>
        <div>
          <h3>Do the work</h3>
          <p>Write the governance framework. Define the refusal spec. Run the sovereignty audit. The badge means you did the work - not that you bought a sticker.</p>
        </div>
      </div>
      <div class="step">
        <span class="step-number">2</span>
        <div>
          <h3>Add the badge</h3>
          <p>Copy the markdown. Paste it in your README. It links back here so anyone can understand what the badge means and adopt it themselves.</p>
        </div>
      </div>
      <div class="step">
        <span class="step-number">3</span>
        <div>
          <h3>That's it</h3>
          <p>No verification process. No registry. No annual renewal fee. You're an adult. If you put the badge on your repo, we trust that you did the work.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container">
    <h2>Why This Exists</h2>
    <p>
      "MIT Licensed" isn't just a badge. It's a signal - a one-line declaration that tells every developer who lands on your repo what they're working with. It compresses a legal framework into two words.
    </p>
    <p>
      Agent governance doesn't have that yet. There's no shorthand for "we defined what our agents refuse to do." No signal for "we audited this system's sovereignty posture." You either read the whole repo or you don't know.
    </p>
    <p>
      These badges are that shorthand. They compress a governance posture into a line in your README. They don't replace the work. They make the work visible.
    </p>
  </section>

  <section class="container">
    <h2>The Standard</h2>
    <p>
      This is an open standard. No trademark. No certification authority. No gatekeeping.
    </p>
    <p>
      The badges link to <a href="https://evoked.dev/badges">evoked.dev/badges</a> so anyone who sees one can understand what it means. The frameworks behind them are $49 each - or build your own. The badge is free regardless.
    </p>
    <p>
      If you want to contribute to the standard - propose new badge categories, suggest improvements, challenge the framework - <a href="mailto:evokesupports@icloud.com">reach out</a>.
    </p>
  </section>

  <section class="container">
    <p class="closing">
      Make the governance visible.
    </p>
  </section>
</BaseLayout>

<style>
  .hero-compact {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .hero-compact h1 {
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    margin-bottom: var(--space-xs);
  }

  .discipline-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--accent-subtle);
    color: var(--accent-warm);
    border-radius: 100px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }

  .tagline {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .lead {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--text-primary);
    text-align: center;
    line-height: 1.6;
  }

  .lead-sub {
    text-align: center;
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-top: var(--space-xs);
  }

  .badge-card {
    border-left: 3px solid var(--accent-warm);
    padding: var(--space-md) var(--space-md) var(--space-md) var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .badge-preview {
    margin-bottom: var(--space-sm);
  }

  .badge-preview img {
    display: block;
  }

  .badge-description {
    color: var(--text-primary);
    font-size: 1.05rem;
    line-height: 1.5;
    margin-bottom: var(--space-sm);
  }

  .badge-snippet {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    padding: var(--space-sm);
    margin-bottom: var(--space-sm);
    overflow-x: auto;
  }

  .snippet-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: var(--space-xs);
  }

  .badge-snippet code {
    font-size: 0.8rem;
    color: var(--text-secondary);
    word-break: break-all;
    white-space: pre-wrap;
  }

  .badge-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0;
  }

  .steps {
    margin-top: var(--space-md);
  }

  .step {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
    align-items: flex-start;
  }

  .step-number {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--accent-warm);
    line-height: 1;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }

  .step h3 {
    margin-top: 0;
    font-size: 1.1rem;
  }

  .step p {
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  .closing {
    text-align: center;
    font-style: italic;
    color: var(--text-muted);
    margin-top: var(--space-lg);
  }

  @media (max-width: 600px) {
    .badge-snippet code {
      font-size: 0.7rem;
    }

    .step {
      gap: var(--space-sm);
    }
  }
</style>
