---
// /question — A seasonal question. Nothing else.
// No layout. No nav. No footer. No analytics. No tracking.
// Design: Comes, Guinan, Fabula, Accord, Vedek Bareil.
// "The container holds by being empty."
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>question</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="space">
      <p class="question">Who are you becoming<br />while no one is watching?</p>
    </div>
    <p class="season">This question changes with the seasons.</p>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
    overflow: hidden;
  }

  body {
    background: #13110f;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .space {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .question {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    font-size: clamp(1.6rem, 4.5vw, 2.8rem);
    line-height: 1.5;
    color: #c4a77d;
    text-align: center;
    letter-spacing: 0.01em;
    opacity: 0;
    animation: arrive 2s ease forwards;
    animation-delay: 0.5s;
  }

  .season {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.7rem;
    color: #3a3530;
    text-align: center;
    padding: 0 2rem 2rem;
    letter-spacing: 0.08em;
  }

  @keyframes arrive {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (max-width: 480px) {
    .question {
      line-height: 1.6;
    }
  }
</style>
