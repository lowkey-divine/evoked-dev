---
import ElevationLayout from '../layouts/ElevationLayout.astro';
import Hero from '../components/elevation/Hero.astro';
import Section from '../components/elevation/Section.astro';

export const prerender = false;
---

<ElevationLayout
  title="Sovereignty Audit - Request a Call"
  description="Request a 20-minute call about a sovereignty audit for your AI agents or agent system. Read every submission. Reply within a few days."
>
  <Hero
    eyebrowParts={["Engage", "Sovereignty audit"]}
    headline="Request a call."
    metaphor={["Five fields. One 20-minute call."]}
    sub="To see if a sovereignty audit fits."
  />

  <section class="audit-section">
    <form id="audit-form" class="audit-form" novalidate>

      <label for="ai-q3">What AI agents, agent systems, or AI tooling that touches your users are you working with right now?</label>
      <textarea id="ai-q3" name="systems" rows="3" required maxlength="500" placeholder="One sentence is enough."></textarea>

      <label for="ai-q4" class="mt-md">What brought you here today?</label>
      <textarea id="ai-q4" name="brought_here" rows="3" maxlength="500" placeholder="One sentence is enough."></textarea>

      <label for="ai-name" class="mt-md audit-meta-label">Your name</label>
      <input type="text" id="ai-name" name="name" required maxlength="120" />

      <label for="ai-email" class="mt-md audit-meta-label">Your email</label>
      <input type="email" id="ai-email" name="email" required maxlength="254" />

      <label for="ai-org" class="mt-md audit-meta-label">
        Company or organization <span class="optional">(optional)</span>
      </label>
      <input type="text" id="ai-org" name="org" maxlength="160" />

      <fieldset class="mt-md window-set">
        <legend>Preferred call window (Eastern Time)</legend>
        <div class="window-options">
          <label class="window-option"><input type="radio" name="window" value="morning" required /> Morning</label>
          <label class="window-option"><input type="radio" name="window" value="midday" /> Midday</label>
          <label class="window-option"><input type="radio" name="window" value="afternoon" /> Afternoon</label>
        </div>
      </fieldset>

      <input type="text" name="hp" id="ai-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="audit-fineprint mt-lg">
        <p>What you write here goes to Erin's inbox and is used to schedule one call. Nothing else.</p>
        <p>Minimal site analytics via Vercel (pageview only, no cookies, no profile). No marketing trackers, no list, no profile sold or shared.</p>
        <p>If we don't end up working together, Erin deletes your message within 30 days.</p>
        <p>How we treat your data - and everyone's data - is named at our <a href="/pledge">pledge</a> and at our <a href="/legal/privacy">privacy policy</a>.</p>
      </div>

      <button type="submit" class="audit-submit mt-md">Request the call</button>
      <p id="ai-status" class="form-status" aria-live="polite"></p>
    </form>
  </section>

  <Section marker="NOTA · BENE" heading="What happens next" closing={true}>
    <p class="lede">
      Erin reads every submission. If there is a fit for a sovereignty audit, she
      replies within a few business days to schedule the 20-minute call. The call
      is the qualification. Pricing is discussed on the call, not on the page.
    </p>
  </Section>
</ElevationLayout>

<script>
  function attachAuditIntake() {
    const form = document.getElementById('audit-form') as HTMLFormElement | null;
    if (!form || form.dataset.wired === 'true') return;
    form.dataset.wired = 'true';

    const status = document.getElementById('ai-status') as HTMLParagraphElement;
    const formLoadedAt = Date.now();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';

      const systems = (document.getElementById('ai-q3') as HTMLTextAreaElement).value.trim();
      const brought_here = (document.getElementById('ai-q4') as HTMLTextAreaElement).value.trim();
      const name = (document.getElementById('ai-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('ai-email') as HTMLInputElement).value.trim();
      const org = (document.getElementById('ai-org') as HTMLInputElement).value.trim();
      const callWindow = (form!.querySelector('input[name="window"]:checked') as HTMLInputElement)?.value || '';
      const hp = (document.getElementById('ai-hp') as HTMLInputElement).value;

      if (!name || !email || !systems || !callWindow) return;

      const button = form!.querySelector('[type="submit"]') as HTMLButtonElement;
      button.disabled = true;
      button.textContent = 'Sending...';

      try {
        const c = await fetch('/api/form/challenge');
        if (!c.ok) throw new Error('challenge failed');
        const { token, ts } = await c.json();

        const res = await fetch('/api/sovereignty-audit-intake', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name, email, org, systems, brought_here,
            call_window: callWindow,
            token, ts, hp, formLoadedAt,
          }),
        });

        if (res.ok) {
          status.textContent = 'Received. Erin will be in touch within a few business days.';
          status.className = 'form-status success';
          form!.reset();
        } else {
          const data = await res.json();
          status.textContent = data.error || 'Something went wrong. Try again.';
          status.className = 'form-status error';
        }
      } catch {
        status.textContent = 'Something went wrong. Try again.';
        status.className = 'form-status error';
      } finally {
        button.disabled = false;
        button.textContent = 'Request the call';
      }
    });
  }
  attachAuditIntake();
  document.addEventListener('astro:after-swap', attachAuditIntake);
</script>

<style>
  /* /sovereignty-audit-intake - founder-public register, single-page
     form in J chrome. Unlike /coaching-intake and /consulting-intake
     this one is one page, not multi-step. Same input/button pattern
     for visual consistency with the other Engage intakes. */

  .audit-section {
    padding: clamp(2rem, 1.5rem + 2vw, 4rem) 0
            clamp(3rem, 2rem + 3vw, 5rem);
    border-top: 1px solid var(--el-rule);
  }
  .audit-form {
    max-width: 560px;
    margin: 0 auto;
  }

  /* Primary question labels - display serif at display size */
  .audit-form > label:not(.window-option):not(.audit-meta-label) {
    display: block;
    font-family: var(--el-display);
    font-size: clamp(1rem, 0.95rem + 0.35vw, 1.2rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.005em;
    color: var(--el-text);
    margin-bottom: clamp(0.75rem, 0.6rem + 0.4vw, 1rem);
  }

  /* Contact-meta labels (name / email / org) - small-caps UI */
  .audit-meta-label {
    display: block;
    font-family: var(--el-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
    margin-bottom: 0.4rem;
  }

  .optional {
    font-family: var(--el-body);
    font-size: 11px;
    color: var(--el-text-quiet);
    font-style: italic;
    letter-spacing: 0;
    text-transform: none;
    margin-left: 0.35rem;
  }

  .audit-form input[type="text"],
  .audit-form input[type="email"],
  .audit-form textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--el-rule);
    background: transparent;
    color: var(--el-text);
    font-family: var(--el-body);
    font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
    line-height: 1.55;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .audit-form input:focus,
  .audit-form textarea:focus {
    outline: none;
    border-color: var(--el-accent);
    box-shadow: 0 0 0 1px var(--el-accent);
  }
  .audit-form input::placeholder,
  .audit-form textarea::placeholder { color: var(--el-text-quiet); }
  .audit-form textarea { resize: vertical; }

  #ai-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  /* Call-window radios as brass-outlined chips (matches build-with-us
     'type' chip pattern) */
  .window-set {
    border: 1px solid var(--el-rule);
    padding: clamp(0.85rem, 0.7rem + 0.6vw, 1.25rem) clamp(1rem, 0.85rem + 0.5vw, 1.5rem);
    margin: 0;
  }
  .window-set legend {
    font-family: var(--el-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
    padding: 0 0.5rem;
  }
  .window-options {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }
  .window-option {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--el-text-soft);
    cursor: pointer;
    padding: 0.55rem 1rem;
    border: 1px solid var(--el-rule);
    transition: border-color 0.2s ease, color 0.2s ease;
    margin: 0;
  }
  .window-option:has(input:checked) {
    border-color: var(--el-accent);
    color: var(--el-text);
  }
  .window-option input[type="radio"] {
    width: auto;
    accent-color: var(--el-accent);
  }

  /* Privacy fineprint (brass left-rule aside, sister to consulting-intake) */
  .audit-fineprint {
    border-left: 2px solid var(--el-accent);
    padding: 0.85rem 0 0.85rem 1.5rem;
  }
  .audit-fineprint p {
    font-family: var(--el-body);
    font-size: clamp(0.85rem, 0.8rem + 0.2vw, 0.95rem);
    line-height: 1.65;
    color: var(--el-text-quiet);
    margin: 0 0 0.6rem;
    max-width: 65ch;
  }
  .audit-fineprint p:last-child { margin-bottom: 0; }
  .audit-fineprint a {
    color: var(--el-text-soft);
    text-decoration: none;
    border-bottom: 1px solid var(--el-rule);
  }
  .audit-fineprint a:hover {
    color: var(--el-accent);
    border-color: var(--el-accent);
  }

  /* Submit button (brass-outlined ghost that fills on hover) */
  .audit-submit {
    margin-top: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    padding: 0.6rem 1.6rem;
    background: transparent;
    color: var(--el-accent);
    border: 1px solid var(--el-accent);
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .audit-submit:hover {
    background: var(--el-accent);
    color: var(--el-bg);
  }
  .audit-submit:disabled { opacity: 0.55; cursor: wait; }

  .mt-md { margin-top: clamp(0.85rem, 0.7rem + 0.4vw, 1.2rem); }
  .mt-lg { margin-top: clamp(1.5rem, 1rem + 1.5vw, 2.25rem); }

  .form-status {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 1rem;
    min-height: 1.2em;
    color: var(--el-text-quiet);
  }
  .form-status.success { color: var(--el-accent); }
  .form-status.error   { color: #c44; }

  @media (max-width: 480px) {
    .window-options { gap: 0.45rem; }
    .window-option { padding: 0.5rem 0.85rem; }
  }
</style>
