---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout
  title="Sovereignty Audit - Request a Call"
  description="Request a 20-minute call about a sovereignty audit for your AI agents or agent system. Read every submission. Reply within a few days."
>
  <div class="hero-small">
    <h1>Request a call.</h1>
    <p class="tagline">Five fields. One 20-minute call to see if a sovereignty audit fits.</p>
  </div>

  <section class="container">
    <form id="audit-form" class="intake-form">

      <label for="ai-q3">What AI agents, agent systems, or AI tooling that touches your users are you working with right now?</label>
      <textarea id="ai-q3" name="systems" rows="3" required maxlength="500" placeholder="One sentence is enough."></textarea>

      <label for="ai-q4" class="mt-md">What brought you here today?</label>
      <textarea id="ai-q4" name="brought_here" rows="3" maxlength="500" placeholder="One sentence is enough."></textarea>

      <label for="ai-name" class="mt-md">Your name</label>
      <input type="text" id="ai-name" name="name" required maxlength="120" />

      <label for="ai-email" class="mt-md">Your email</label>
      <input type="email" id="ai-email" name="email" required maxlength="254" />

      <label for="ai-org" class="mt-md">Company or organization <span class="optional">(optional)</span></label>
      <input type="text" id="ai-org" name="org" maxlength="160" />

      <fieldset class="mt-md window-set">
        <legend>Preferred call window (Eastern Time)</legend>
        <label class="radio-label"><input type="radio" name="window" value="morning" required /> Morning</label>
        <label class="radio-label"><input type="radio" name="window" value="midday" /> Midday</label>
        <label class="radio-label"><input type="radio" name="window" value="afternoon" /> Afternoon</label>
      </fieldset>

      <input type="text" name="hp" id="ai-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="data-handling mt-lg">
        <p>What you write here goes to Erin's inbox and is used to schedule one call. Nothing else.</p>
        <p>Minimal site analytics via Vercel (pageview only, no cookies, no profile). No marketing trackers, no list, no profile sold or shared.</p>
        <p>If we don't end up working together, Erin deletes your message within 30 days.</p>
        <p>How we treat your data - and everyone's data - is named at our <a href="/pledge">pledge</a>.</p>
      </div>

      <button type="submit" class="btn btn-primary mt-md">Request the call</button>
      <p id="ai-status" class="form-status" aria-live="polite"></p>
    </form>
  </section>

  <section class="container">
    <div class="what-happens">
      <h2>What happens next</h2>
      <p>Erin reads every submission. If there is a fit for a sovereignty audit, she replies within a few business days to schedule the 20-minute call. The call is the qualification. Pricing is discussed on the call, not on the page.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement;
  const status = document.getElementById('ai-status') as HTMLParagraphElement;
  const formLoadedAt = Date.now();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = '';

    const systems = (document.getElementById('ai-q3') as HTMLTextAreaElement).value.trim();
    const brought_here = (document.getElementById('ai-q4') as HTMLTextAreaElement).value.trim();
    const name = (document.getElementById('ai-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('ai-email') as HTMLInputElement).value.trim();
    const org = (document.getElementById('ai-org') as HTMLInputElement).value.trim();
    const callWindow = (form.querySelector('input[name="window"]:checked') as HTMLInputElement)?.value || '';
    const hp = (document.getElementById('ai-hp') as HTMLInputElement).value;

    if (!name || !email || !systems || !callWindow) return;

    const button = form.querySelector('[type="submit"]') as HTMLButtonElement;
    button.disabled = true;
    button.textContent = 'Sending...';

    try {
      const c = await fetch('/api/form/challenge');
      if (!c.ok) throw new Error('challenge failed');
      const { token, ts } = await c.json();

      const res = await fetch('/api/sovereignty-audit-intake', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name, email, org, systems, brought_here,
          call_window: callWindow,
          token, ts, hp, formLoadedAt,
        }),
      });

      if (res.ok) {
        status.textContent = 'Received. Erin will be in touch within a few business days.';
        status.className = 'form-status success';
        form.reset();
      } else {
        const data = await res.json();
        status.textContent = data.error || 'Something went wrong. Try again.';
        status.className = 'form-status error';
      }
    } catch {
      status.textContent = 'Something went wrong. Try again.';
      status.className = 'form-status error';
    } finally {
      button.disabled = false;
      button.textContent = 'Request the call';
    }
  });
</script>

<style>
  .hero-small {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .hero-small h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-xs);
  }

  .hero-small .tagline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .intake-form {
    max-width: 560px;
    margin: 0 auto;
  }

  .intake-form label:not(.radio-label):not(.type-option) {
    display: block;
    font-size: 1.05rem;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
    font-family: var(--font-display);
    line-height: 1.4;
  }

  .optional {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .intake-form input[type="text"],
  .intake-form input[type="email"],
  .intake-form textarea {
    width: 100%;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-body, inherit);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .intake-form input:focus,
  .intake-form textarea:focus {
    outline: none;
    border-color: var(--accent-warm);
  }

  .intake-form input::placeholder,
  .intake-form textarea::placeholder {
    color: var(--text-muted);
  }

  .intake-form textarea {
    resize: vertical;
  }

  #ai-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .window-set {
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    padding: var(--space-sm) var(--space-md);
  }

  .window-set legend {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--text-primary);
    padding: 0 var(--space-xs);
  }

  .radio-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-right: var(--space-md);
    font-size: 0.95rem;
    color: var(--text-secondary);
    cursor: pointer;
  }

  .data-handling {
    border-left: 2px solid var(--border-subtle);
    padding: var(--space-sm) var(--space-md);
    background: rgba(255, 255, 255, 0.02);
    border-radius: 4px;
  }

  .data-handling p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-xs);
  }

  .data-handling p:last-child {
    margin-bottom: 0;
  }

  .data-handling a {
    color: var(--accent-warm);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .btn-primary {
    background: var(--accent-warm);
    color: var(--bg-deep);
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--accent-glow);
    color: var(--bg-deep);
  }

  .mt-md { margin-top: var(--space-md); }
  .mt-lg { margin-top: var(--space-lg); }

  .form-status {
    font-size: 0.9rem;
    margin-top: var(--space-sm);
    min-height: 1.2em;
  }

  .form-status.success {
    color: var(--accent-warm);
  }

  .form-status.error {
    color: #e57373;
  }

  .what-happens {
    max-width: 560px;
    margin: var(--space-lg) auto 0;
  }

  .what-happens h2 {
    font-size: 1.3rem;
    margin-bottom: var(--space-sm);
  }

  .what-happens p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
</style>
