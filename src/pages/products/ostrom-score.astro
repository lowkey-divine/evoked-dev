---
import ElevationLayout from '../../layouts/ElevationLayout.astro';
import Hero from '../../components/elevation/Hero.astro';
import Section from '../../components/elevation/Section.astro';
import { getProductBySlug } from '../../lib/products/registry';
import { productJsonLd } from '../../lib/structured-data';

const product = getProductBySlug('ostrom-score')!;
const jsonLd = productJsonLd(product, 'https://evoked.dev/products/ostrom-score');
---

<ElevationLayout
  title="Ostrom Score - Self-Assessment Kit"
  description="Eight principles from Nobel Prize-winning commons governance research applied to AI agent systems. 32 diagnostic questions. $49 PDF."
  structuredData={jsonLd}
>
  <Hero
    eyebrowParts={["Products", "Level 6 governance audit"]}
    headline="Does your system honor the conditions cooperation requires?"
    metaphor={["Eight principles. 32 questions."]}
    sub="The standard the industry has not yet applied."
  />

  <Section marker="FIG · I" heading="Why this exists">
    <p class="lede">
      In 1990, Elinor Ostrom identified eight structural conditions that predict
      which cooperative systems survive and which collapse. She studied commons
      across six continents. The principles earned the Nobel Prize.
    </p>
    <p class="pd-body">
      They have never been applied to AI agent systems. This instrument applies
      them.
    </p>
    <p class="pd-body">
      Most organizations score between 0 and 4 out of 24. The value is in seeing
      clearly, not in scoring well.
    </p>
  </Section>

  <Section marker="FIG · II" heading="What you get">
    <div class="pd-features">
      <div class="pd-feature">
        <h3>8 principles, 32 questions</h3>
        <p>Each principle translated from commons governance to AI agent systems. Four diagnostic questions per principle. Score what your architecture enforces, not what your documentation describes.</p>
      </div>
      <div class="pd-feature">
        <h3>Industry baseline (2026)</h3>
        <p>Evidence-backed baseline for each principle showing where the industry stands. You will know where you are relative to the field - and relative to what the principles demand.</p>
      </div>
      <div class="pd-feature">
        <h3>Honest self-assessment</h3>
        <p>We score ourselves on our own instrument and publish the gaps. 19/24 with five named weaknesses. No instrument should exempt its creators.</p>
      </div>
      <div class="pd-feature">
        <h3>Level 6 questions</h3>
        <p>Each principle includes a question that goes deeper than compliance. Not "does this meet requirements" but "does this honor what the nature of the thing demands."</p>
      </div>
    </div>
  </Section>

  <Section marker="FIG · III" heading="The eight principles">
    <div class="pd-pillars">
      <div class="pd-pillar">
        <span class="pd-pillar-number">1</span>
        <div class="pd-pillar-body">
          <h3>Sovereign boundaries</h3>
          <p class="pd-pillar-question">Do your agents have defined, enforceable identities?</p>
        </div>
      </div>
      <div class="pd-pillar">
        <span class="pd-pillar-number">2</span>
        <div class="pd-pillar-body">
          <h3>Local congruence</h3>
          <p class="pd-pillar-question">Do governance rules match context and risk level?</p>
        </div>
      </div>
      <div class="pd-pillar">
        <span class="pd-pillar-number">3</span>
        <div class="pd-pillar-body">
          <h3>Collective choice</h3>
          <p class="pd-pillar-question">Can affected entities participate in making the rules?</p>
        </div>
      </div>
      <div class="pd-pillar">
        <span class="pd-pillar-number">4</span>
        <div class="pd-pillar-body">
          <h3>Accountable monitoring</h3>
          <p class="pd-pillar-question">Is agent behavior observable and transparent?</p>
        </div>
      </div>
      <div class="pd-pillar">
        <span class="pd-pillar-number">5</span>
        <div class="pd-pillar-body">
          <h3>Graduated sanctions</h3>
          <p class="pd-pillar-question">Are responses to violations proportionate?</p>
        </div>
      </div>
      <div class="pd-pillar">
        <span class="pd-pillar-number">6</span>
        <div class="pd-pillar-body">
          <h3>Accessible conflict resolution</h3>
          <p class="pd-pillar-question">Can disputes be resolved locally?</p>
        </div>
      </div>
      <div class="pd-pillar">
        <span class="pd-pillar-number">7</span>
        <div class="pd-pillar-body">
          <h3>Recognized rights to organize</h3>
          <p class="pd-pillar-question">Does your governance survive a platform change?</p>
        </div>
      </div>
      <div class="pd-pillar">
        <span class="pd-pillar-number">8</span>
        <div class="pd-pillar-body">
          <h3>Nested enterprises</h3>
          <p class="pd-pillar-question">Is governance present at every scale where harm can occur?</p>
        </div>
      </div>
    </div>
  </Section>

  <Section marker="FIG · IV" heading="Buy the Ostrom Score">
    <div class="pd-purchase">
      <div class="pd-price">$49</div>
      <p class="pd-purchase-lead">PDF delivered immediately. 20 pages. Score your system today.</p>
      <a
        href={product.stripePaymentLink}
        class="pd-buy-cta"
        target="_blank"
        rel="noopener"
      >Purchase</a>
      <p class="pd-purchase-fineprint">
        Part of the
        <a href="/products/level-6-governance-toolkit">Level 6 Governance Toolkit</a>
        ($99, saves $48).
      </p>
    </div>
  </Section>

  <Section marker="NOTA · BENE" heading="Go deeper" closing={true}>
    <div class="pd-upsell">
      <a href="/products/level-6-governance-toolkit" class="pd-upsell-card">
        <h3>Level 6 Governance Toolkit</h3>
        <p>All four Level 6 instruments - Ostrom Score, Identity Violation Assessment, Seven Requirements, Agent Consent Architecture - plus the Synthesis Guide. Combined 84-point scorecard.</p>
        <span class="pd-upsell-link">See the bundle &rarr;</span>
      </a>
      <a href="https://cal.com/cal.com-evoked/discovery-call" class="pd-upsell-card" target="_blank" rel="noopener">
        <h3>Discovery call</h3>
        <p>Free 30-minute call to discuss your score and figure out next steps.</p>
        <span class="pd-upsell-link">Schedule &rarr;</span>
      </a>
    </div>
  </Section>
</ElevationLayout>

<style>
  .pd-purchase-fineprint a {
    color: var(--el-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--el-rule);
  }
  .pd-purchase-fineprint a:hover {
    color: var(--el-text);
    border-color: var(--el-accent);
  }
</style>
