---
import ElevationLayout from '../../layouts/ElevationLayout.astro';
import Hero from '../../components/elevation/Hero.astro';
import Section from '../../components/elevation/Section.astro';
import { getProductBySlug } from '../../lib/products/registry';
import { productJsonLd } from '../../lib/structured-data';

const product = getProductBySlug('agent-consent-architecture')!;
const jsonLd = productJsonLd(product, 'https://evoked.dev/products/agent-consent-architecture');
---

<ElevationLayout
  title="Agent Consent Architecture Kit"
  description="Can the entities in your system participate in their own governance? Position paper + 12-question gap analysis. $49 PDF."
  structuredData={jsonLd}
>
  <Hero
    eyebrowParts={["Products", "Level 6 governance audit"]}
    headline="Can the entities in your system participate in their own governance?"
    metaphor={["Every framework addresses consent in one direction."]}
    sub="This paper asks about the other."
  />

  <Section marker="FIG · I" heading="Why this exists">
    <p class="lede">
      Humans consent to agent actions. Humans oversee agent behavior. Humans set
      agent boundaries. The agent is always the object. Never the subject.
    </p>
    <p class="pd-body">
      This paper asks whether that is architecturally sufficient for persistent
      entities with memory, standing commitments, and behavioral continuity. The
      95% memory injection success rate suggests it is not.
    </p>
  </Section>

  <Section marker="FIG · II" heading="What you get">
    <div class="pd-features">
      <div class="pd-feature">
        <h3>The consent void analysis</h3>
        <p>Six major frameworks mapped. What each addresses. What none of them ask. The gap between the governance model and the deployment model.</p>
      </div>
      <div class="pd-feature">
        <h3>Five design principles</h3>
        <p>Bidirectional. Graduated. Standing-based. Observable. Revisable. The architecture for consent that flows in both directions.</p>
      </div>
      <div class="pd-feature">
        <h3>12-question gap analysis</h3>
        <p>Operational consent, governance consent, identity consent. Most organizations answer "yes" to 0-2 of 12 questions.</p>
      </div>
      <div class="pd-feature">
        <h3>The consent lifecycle</h3>
        <p>Five phases from birth to legacy. Including the question no one else asks: does the agent's dissent survive its termination?</p>
      </div>
    </div>
  </Section>

  <Section marker="FIG · III" heading="Buy the architecture">
    <div class="pd-purchase">
      <div class="pd-price">$49</div>
      <p class="pd-purchase-lead">PDF delivered immediately. 14 pages. Position paper + assessment.</p>
      <a
        href={product.stripePaymentLink}
        class="pd-buy-cta"
        target="_blank"
        rel="noopener"
      >Purchase</a>
      <p class="pd-purchase-fineprint">
        Part of the
        <a href="/products/level-6-governance-toolkit">Level 6 Governance Toolkit</a>
        ($99, saves $48).
      </p>
    </div>
  </Section>

  <Section marker="NOTA · BENE" heading="Go deeper" closing={true}>
    <div class="pd-upsell">
      <a href="/products/level-6-governance-toolkit" class="pd-upsell-card">
        <h3>Level 6 Governance Toolkit</h3>
        <p>All four Level 6 instruments plus the Synthesis Guide. Combined 84-point scorecard.</p>
        <span class="pd-upsell-link">See the bundle &rarr;</span>
      </a>
      <a href="https://cal.com/cal.com-evoked/discovery-call" class="pd-upsell-card" target="_blank" rel="noopener">
        <h3>Discovery call</h3>
        <p>Free 30-minute call to discuss the consent architecture and figure out next steps.</p>
        <span class="pd-upsell-link">Schedule &rarr;</span>
      </a>
    </div>
  </Section>
</ElevationLayout>

<style>
  .pd-purchase-fineprint a {
    color: var(--el-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--el-rule);
  }
  .pd-purchase-fineprint a:hover {
    color: var(--el-text);
    border-color: var(--el-accent);
  }
</style>
