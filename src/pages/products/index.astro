---
import BaseLayout from '../../layouts/BaseLayout.astro';

const productSchemas = [
  {
    "@type": "Product",
    "name": "Governance Score Card",
    "description": "A one-page interpretation guide for your agent governance scan results. What each gap means, the risk it carries, and one concrete next step per finding.",
    "url": "https://evoked.dev/products/governance-score-card",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "1.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Agent Governance Templates (Guided)",
    "description": "Five governance templates with worked examples, common mistakes, and completion checklists.",
    "url": "https://evoked.dev/products/governance-templates-guided",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "5.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Agent Governance Implementation Guide",
    "description": "A 25-page implementation guide with framework-specific examples for CrewAI, LangGraph, and Pydantic AI.",
    "url": "https://evoked.dev/products/governance-implementation-guide",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "9.99", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Sovereignty Assessment Toolkit",
    "description": "A structured self-assessment framework with a 47-point checklist across 7 domains, scoring rubric, and action plan template.",
    "url": "https://evoked.dev/products/sovereignty-toolkit",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Trust Architecture Blueprint",
    "description": "A four-pillar blueprint for agent trust: identity architecture, memory architecture, governance architecture, and refusal rights.",
    "url": "https://evoked.dev/products/trust-architecture-blueprint",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Agent Voice Architecture Guide",
    "description": "A complete guide to voice design principles, sovereignty language, voice specification templates, quality checks, and refusal voice patterns.",
    "url": "https://evoked.dev/products/agent-voice-architecture-guide",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Agent Governance Starter Kit",
    "description": "Templates and frameworks for agent charters, boundary specifications, drift monitoring, accountability protocols, and authority structures.",
    "url": "https://evoked.dev/products/agent-governance-starter-kit",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Agent Restraint Specification Template",
    "description": "A complete specification template for agent refusal categories, fail-closed/open decisions, accountability architecture, and adversarial testing.",
    "url": "https://evoked.dev/products/agent-restraint-specification",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Agent Memory Architecture Guide",
    "description": "A complete framework for memory types, memory governance, session protocols, the canonical rule for resolving memory conflicts, and retention policies.",
    "url": "https://evoked.dev/products/agent-memory-architecture-guide",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Ostrom Score - Self-Assessment Kit",
    "description": "Commons governance assessment based on Elinor Ostrom's eight design principles applied to AI agent systems. 32 diagnostic questions, 0-24 scoring.",
    "url": "https://evoked.dev/products/ostrom-score",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Identity Violation Assessment Kit",
    "description": "Eight assessment domains evaluating whether AI agent systems can distinguish genuine entities from compromised ones. 32 questions, identity violation taxonomy.",
    "url": "https://evoked.dev/products/identity-violation-assessment",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Agent Consent Architecture Kit",
    "description": "Position paper and 12-question gap analysis on bidirectional agent consent. Five design principles, three consent domains, consent lifecycle.",
    "url": "https://evoked.dev/products/agent-consent-architecture",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "49.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Level 6 Governance Toolkit",
    "description": "Complete Level 6 Governance Audit: Ostrom Score, Identity Violation Assessment, Agent Consent Architecture, plus Synthesis Guide with 60-point scorecard.",
    "url": "https://evoked.dev/products/level-6-governance-toolkit",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "99.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  },
  {
    "@type": "Product",
    "name": "Trust Architecture Complete",
    "description": "All four trust architecture products: Trust Architecture Blueprint, Agent Voice Architecture Guide, Agent Governance Starter Kit, and Agent Restraint Specification Template.",
    "url": "https://evoked.dev/products/trust-architecture-complete",
    "brand": { "@type": "Organization", "name": "Evoked" },
    "offers": { "@type": "Offer", "price": "149.00", "priceCurrency": "USD", "availability": "https://schema.org/InStock" }
  }
];
---

<BaseLayout title="Products" description="Sovereignty-honoring frameworks for AI agent systems by Erin Stanley. Assessment toolkits, trust architecture, voice design, governance, restraint, and memory.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": productSchemas
  })} />

  <div class="hero hero-compact">
    <p class="recognition">You want to build something that honors the people who use it.</p>
    <h1>Frameworks for the work your agents are already doing.</h1>
    <p class="tagline">Sovereignty, governance, and restraint - built in practice, not in theory.</p>
  </div>

  <section class="container">
    <h2>Start Here</h2>
    <p class="section-intro">Answer five questions about your agent system. Understand the gaps. Build from there.</p>
    <div class="products-grid">
      <a href="/products/governance-score-card" class="product-card">
        <span class="discipline-badge">Quick Assessment</span>
        <h3>Governance Score Card</h3>
        <p>Five governance questions about your agent system. This card tells you what the score means and what to fix first.</p>
        <span class="price">$1</span>
      </a>
      <a href="/products/governance-templates-guided" class="product-card">
        <span class="discipline-badge">Implementation Kit</span>
        <h3>Agent Governance Templates (Guided)</h3>
        <p>The five governance templates with filled-in examples from a real system. Charter, restraint, memory, deliberation, drift.</p>
        <span class="price">$5</span>
      </a>
      <a href="/products/governance-implementation-guide" class="product-card">
        <span class="discipline-badge">Implementation Guide</span>
        <h3>Agent Governance Implementation Guide</h3>
        <p>Add governance to the agent you already built. Framework-specific for CrewAI, LangGraph, and Pydantic AI. 25 pages.</p>
        <span class="price">$9.99</span>
      </a>
    </div>
  </section>

  <section class="container">
    <h2>Go Deeper</h2>
    <div class="products-grid">
      <a href="/products/sovereignty-toolkit" class="product-card">
        <span class="discipline-badge">Evaluation Design</span>
        <h3>Sovereignty Assessment Toolkit</h3>
        <p>47-point checklist across 7 domains. Evaluate whether the technology you use or build honors human sovereignty.</p>
        <span class="price">$49</span>
      </a>
      <a href="/products/trust-architecture-blueprint" class="product-card">
        <span class="discipline-badge">Specification Engineering</span>
        <h3>Trust Architecture Blueprint</h3>
        <p>Four pillars of agent trust: identity, memory, governance, and refusal rights. The foundation your agents are missing.</p>
        <span class="price">$49</span>
      </a>
      <a href="/products/agent-voice-architecture-guide" class="product-card">
        <span class="discipline-badge">Intent Engineering</span>
        <h3>Agent Voice Architecture Guide</h3>
        <p>Design agent voices that protect, respect, and nurture - in that order. Sovereignty language audit and refusal voice patterns.</p>
        <span class="price">$49</span>
      </a>
      <a href="/products/agent-governance-starter-kit" class="product-card">
        <span class="discipline-badge">Governance Architecture</span>
        <h3>Agent Governance Starter Kit</h3>
        <p>Charter, boundaries, drift thresholds, and accountability. The governance framework your agents need from day one.</p>
        <span class="price">$49</span>
      </a>
      <a href="/products/agent-restraint-specification" class="product-card">
        <span class="discipline-badge">Constraint Architecture</span>
        <h3>Agent Restraint Specification Template</h3>
        <p>Define what your agents must refuse to do. Boundary audit, refusal categories, fail-mode decisions, and adversarial testing.</p>
        <span class="price">$49</span>
      </a>
      <a href="/products/agent-memory-architecture-guide" class="product-card">
        <span class="discipline-badge">Context Engineering</span>
        <h3>Agent Memory Architecture Guide</h3>
        <p>Design what your agents remember, what they forget, and who decides. Memory governance, session protocols, and the canonical rule.</p>
        <span class="price">$49</span>
      </a>
    </div>
  </section>

  <section class="container">
    <h2>Level 6 Governance Audit</h2>
    <p class="section-intro">Three instruments that measure what no one else measures. Commons health. Entity integrity. Participation architecture.</p>
    <div class="products-grid">
      <a href="/products/ostrom-score" class="product-card">
        <span class="discipline-badge">Level 6 Governance Audit</span>
        <h3>Ostrom Score</h3>
        <p>Eight principles from Nobel Prize-winning commons governance research. 32 diagnostic questions. Does your system honor the conditions cooperation requires?</p>
        <span class="price">$49</span>
      </a>
      <a href="/products/identity-violation-assessment" class="product-card">
        <span class="discipline-badge">Level 6 Governance Audit</span>
        <h3>Identity Violation Assessment</h3>
        <p>Can your system tell the difference between a genuine entity and a compromised one? 8 domains, 32 questions, four-category violation taxonomy.</p>
        <span class="price">$49</span>
      </a>
      <a href="/products/agent-consent-architecture" class="product-card">
        <span class="discipline-badge">Level 6 Governance Audit</span>
        <h3>Agent Consent Architecture</h3>
        <p>Can the entities in your system participate in their own governance? Position paper + 12-question gap analysis.</p>
        <span class="price">$49</span>
      </a>
    </div>
  </section>

  <section class="container">
    <h2>Bundles</h2>
    <div class="products-grid">
      <a href="/products/level-6-governance-toolkit" class="product-card bundle-card">
        <span class="discipline-badge">Level 6 Governance Audit</span>
        <h3>Level 6 Governance Toolkit</h3>
        <p>All three Level 6 instruments plus the Synthesis Guide. Combined 60-point scorecard.</p>
        <span class="price">$99 <span class="savings-inline">Save $48</span></span>
      </a>
      <a href="/products/trust-architecture-complete" class="product-card bundle-card">
        <span class="discipline-badge">Full Practice</span>
        <h3>Trust Architecture Complete</h3>
        <p>All four trust architecture products - Blueprint, Voice, Governance, and Restraint - in the order they should be built.</p>
        <span class="price">$149 <span class="savings-inline">Save $47</span></span>
      </a>
      <a href="/consulting" class="product-card">
        <span class="discipline-badge">Consulting</span>
        <h3>Governance Audit</h3>
        <p>We audit your agent system hands-on, in your codebase, with your team. Assessment instruments, implementation guidance, and ongoing partnership.</p>
        <span class="price">$5K+</span>
      </a>
    </div>
  </section>

  <section class="container">
    <h2>Not sure where to start?</h2>
    <div class="cta-grid">
      <div class="card">
        <h3>Five Questions for Your Agent System</h3>
        <p>30 seconds. Find out what governance your agents are missing. No signup. No tracking.</p>
        <a href="/diagnostic" class="btn mt-sm">Start Diagnostic</a>
      </div>
      <div class="card">
        <h3>Take the Fit Assessment</h3>
        <p>5 minutes. Find out which products and services align with where you are right now.</p>
        <a href="/fit" class="btn mt-sm">Start Assessment</a>
      </div>
      <div class="card">
        <h3>Book a Discovery Call</h3>
        <p>Free 30-minute call. Talk through your situation and figure out next steps together.</p>
        <a href="https://cal.com/cal.com-evoked/discovery-call" class="btn mt-sm" target="_blank" rel="noopener">Schedule</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-intro {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }

  .section-intro code {
    background: var(--bg-surface);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .hero-compact {
    min-height: 40vh;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .product-card {
    display: block;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: var(--space-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .product-card:hover {
    border-color: var(--accent-warm);
    transform: translateY(-2px);
    color: inherit;
  }

  .bundle-card {
    border: 2px solid var(--accent-warm);
    background: var(--accent-subtle);
  }

  .discipline-badge {
    display: inline-block;
    background: var(--accent-subtle);
    color: var(--accent-warm);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 8px;
    border-radius: 100px;
    margin-bottom: var(--space-xs);
  }

  .bundle-card .discipline-badge {
    background: var(--bg-surface);
  }

  .product-card h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  .product-card p {
    font-size: 0.9rem;
    margin-bottom: var(--space-sm);
    color: var(--text-secondary);
  }

  .price {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--accent-warm);
    font-weight: 500;
  }

  .savings-inline {
    font-size: 0.8rem;
    font-family: var(--font-body, inherit);
    font-weight: 400;
    opacity: 0.8;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-md);
  }

  .cta-grid .card h3 {
    font-size: 1.1rem;
  }

  .cta-grid .card p {
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
