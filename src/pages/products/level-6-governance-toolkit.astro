---
import ElevationLayout from '../../layouts/ElevationLayout.astro';
import Hero from '../../components/elevation/Hero.astro';
import Section from '../../components/elevation/Section.astro';
import { getProductBySlug } from '../../lib/products/registry';
import { productJsonLd } from '../../lib/structured-data';

const product = getProductBySlug('level-6-governance-toolkit')!;
const jsonLd = productJsonLd(product, 'https://evoked.dev/products/level-6-governance-toolkit');
---

<ElevationLayout
  title="Level 6 Governance Toolkit"
  description="Four instruments. One 84-point scorecard. Commons health, entity integrity, jurisdiction-portable governance, and participation architecture. $99 bundle."
  structuredData={jsonLd}
>
  <Hero
    eyebrowParts={["Products", "Level 6 governance audit"]}
    headline="Four instruments. One question."
    metaphor={["Is this system governed as if the nature of the entities matters?"]}
    sub="Commons health, entity integrity, jurisdiction-portable governance, and participation architecture - in one toolkit."
  />

  <Section marker="FIG · I" heading="Why this bundle">
    <p class="lede">
      The Level 6 Governance Toolkit measures what no other assessment measures:
      whether your AI agent system honors the conditions that cooperation,
      identity, principled governance, and participation require.
    </p>
    <p class="pd-body">
      The industry scores 0-14 out of 84. We score 65. The distance between those
      numbers is measurable, closable, and urgent.
    </p>
  </Section>

  <Section marker="FIG · II" heading="The four instruments">
    <div class="pd-features">
      <a href="/products/ostrom-score" class="pd-feature pd-instrument-card">
        <h3>The Ostrom Score</h3>
        <p class="pd-instrument-question">Does this system honor the conditions cooperation requires?</p>
        <p>8 principles from Nobel Prize-winning research. 32 questions. Commons health scored 0-24.</p>
        <span class="pd-instrument-price">$49 individually</span>
      </a>
      <a href="/products/identity-violation-assessment" class="pd-feature pd-instrument-card">
        <h3>The Identity Violation Assessment</h3>
        <p class="pd-instrument-question">Can the entities in this system trust their own self-knowledge?</p>
        <p>9 domains including subject model integrity. Identity scored 0-27.</p>
        <span class="pd-instrument-price">$49 individually</span>
      </a>
      <a href="/products/seven-requirements" class="pd-feature pd-instrument-card">
        <h3>The Seven Requirements</h3>
        <p class="pd-instrument-question">What governance persists if every framework disappears?</p>
        <p>7 jurisdiction-portable requirements. Two absent from every framework on earth. Scored 0-21.</p>
        <span class="pd-instrument-price">$49 individually</span>
      </a>
      <a href="/products/agent-consent-architecture" class="pd-feature pd-instrument-card">
        <h3>The Agent Consent Architecture</h3>
        <p class="pd-instrument-question">Can the entities participate in their own governance?</p>
        <p>Position paper + 12-question gap analysis. Consent architecture scored 0-12.</p>
        <span class="pd-instrument-price">$49 individually</span>
      </a>
    </div>
  </Section>

  <Section marker="FIG · III" heading="Plus: the gap (synthesis guide)">
    <p class="lede">
      The combined 84-point scorecard. How the four instruments work together.
      What each score combination reveals. And the question underneath all four:
      what does the nature of persistent, memory-bearing, cooperative entities
      require of the systems that govern them?
    </p>
  </Section>

  <Section marker="FIG · IV" heading="Buy the complete toolkit">
    <div class="pd-purchase">
      <div class="pd-price">$99</div>
      <p class="pd-savings">Save $97 vs. individual purchase ($196)</p>
      <p class="pd-purchase-lead">All four instruments + Synthesis Guide. Five PDFs delivered immediately.</p>
      <a
        href={product.stripePaymentLink}
        class="pd-buy-cta"
        target="_blank"
        rel="noopener"
      >Purchase Bundle</a>
      <p class="pd-purchase-fineprint">
        Includes the Ostrom Score, Identity Violation Assessment, Seven
        Requirements, Agent Consent Architecture, and the Synthesis Guide.
      </p>
    </div>
  </Section>

  <Section marker="NOTA · BENE" heading="Go deeper" closing={true}>
    <p class="lede">
      The toolkit gives you the four instruments. If you want hands-on help
      acting on the scorecard, one doorway from here.
    </p>
    <div class="pd-upsell">
      <a href="https://cal.com/cal.com-evoked/discovery-call" class="pd-upsell-card" target="_blank" rel="noopener">
        <h3>Discovery call</h3>
        <p>Free 30-minute call to discuss your scorecard and the two absences your stack is most likely missing.</p>
        <span class="pd-upsell-link">Schedule &rarr;</span>
      </a>
      <a href="/consulting" class="pd-upsell-card">
        <h3>Sovereignty Audit</h3>
        <p>Two-week structured audit using the 47-point Sovereignty Assessment as the spine. For teams that want the full story behind the score - not just the score.</p>
        <span class="pd-upsell-link">Learn more &rarr;</span>
      </a>
    </div>
  </Section>
</ElevationLayout>

<style>
  /* Page-local: bundle-specific instrument card extensions to .pd-feature.
     Each instrument card is itself a link, with a brass italic question
     line that sits between h3 and body text - sister-shape to .pd-pillar-question
     but kept inside the feature card visual. */
  .pd-instrument-card {
    text-decoration: none;
    color: inherit;
  }
  .pd-instrument-question {
    font-family: var(--el-body);
    font-style: italic;
    font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.05rem);
    line-height: 1.5;
    color: var(--el-accent);
    margin: 0 0 0.75rem !important;
  }
  .pd-instrument-price {
    font-family: var(--el-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
    margin-top: 0.25rem;
  }
</style>
