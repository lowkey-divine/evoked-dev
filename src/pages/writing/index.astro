---
import { getCollection } from 'astro:content';
import ElevationLayout from '../../layouts/ElevationLayout.astro';
import Hero from '../../components/elevation/Hero.astro';
import Section from '../../components/elevation/Section.astro';

const allPosts = await getCollection('writing', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<ElevationLayout
  title="Writing"
  description="Writing on AI agent governance, sovereignty, trust architecture, and building systems that treat agents as participants - not just tools."
>
  <Hero
    eyebrowParts={["Writing"]}
    headline="Writing."
    metaphor={["On AI agent governance and sovereignty."]}
    sub="On building systems that treat agents as participants, not just tools."
  />

  <Section marker="FIG · I" heading="New to agent governance? Start here.">
    <div class="writing-start">
      <a href="/writing/fifteen-frameworks" class="writing-start-item">
        <span class="writing-start-number">1</span>
        <div class="writing-start-body">
          <h3>Fifteen Frameworks, One Missing Layer</h3>
          <p>What exists, what's missing, and why it matters.</p>
        </div>
      </a>
      <a href="/writing/what-should-your-agent-refuse" class="writing-start-item">
        <span class="writing-start-number">2</span>
        <div class="writing-start-body">
          <h3>What Should Your Agent Refuse?</h3>
          <p>The question nobody's asking - and why the answer changes everything.</p>
        </div>
      </a>
      <a href="/writing/relational-fidelity-metrics" class="writing-start-item">
        <span class="writing-start-number">3</span>
        <div class="writing-start-body">
          <h3>Relational Fidelity Metrics</h3>
          <p>How to measure whether your agent is still itself. Four categories, nine indicators.</p>
        </div>
      </a>
    </div>
  </Section>

  {sortedPosts.length > 0 ? (
    <Section marker="FIG · II" heading="All writing">
      <div class="writing-list">
        {sortedPosts.map((post) => (
          <a href={`/writing/${post.slug}`} class="writing-card">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </Section>
  ) : (
    <Section marker="FIG · II" heading="All writing">
      <p class="lede">Articles coming soon.</p>
    </Section>
  )}

  <Section marker="FIG · III" heading="Newsletter">
    <p class="lede">
      Occasional updates on projects, writing, and building something better.
    </p>
    <form id="newsletter-form" class="writing-newsletter-form" novalidate>
      <div class="writing-newsletter-row">
        <input type="email" id="newsletter-email" name="email" placeholder="your.email@example.com" required aria-label="Email address" />
        <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" class="writing-hp-field" />
        <button type="submit">Subscribe</button>
      </div>
    </form>
    <p id="newsletter-status" class="writing-newsletter-status hidden" aria-live="polite"></p>
  </Section>

  <Section marker="NOTA · BENE" heading="Elsewhere" closing={true}>
    <p class="lede">More writing and work on other platforms.</p>
    <div class="writing-elsewhere">
      <a class="cta cta-secondary" href="https://substack.com/@weevoke" target="_blank" rel="noopener">Substack &rarr;</a>
      <a class="cta cta-secondary" href="https://medium.com/@evokepassion869" target="_blank" rel="noopener">Medium &rarr;</a>
      <a class="cta cta-secondary" href="https://github.com/lowkey-divine" target="_blank" rel="noopener">GitHub &rarr;</a>
    </div>
  </Section>
</ElevationLayout>

<script>
  function attachWritingNewsletter() {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    if (!form || form.dataset.wired === 'true') return;
    form.dataset.wired = 'true';

    const status = document.getElementById('newsletter-status') as HTMLParagraphElement;
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    const hpInput = form.querySelector('input[name="website"]') as HTMLInputElement;
    const button = form.querySelector('button') as HTMLButtonElement;

    const showError = (msg: string) => {
      button.disabled = false;
      button.textContent = 'Subscribe';
      status.textContent = msg;
      status.classList.remove('hidden', 'success');
      status.classList.add('error');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;

      if (hpInput.value) {
        button.textContent = 'Thank you ✓';
        emailInput.value = '';
        return;
      }

      button.disabled = true;
      button.textContent = 'Subscribing...';
      status.textContent = '';
      status.classList.remove('error', 'success', 'hidden');

      try {
        const c = await fetch('/api/newsletter/challenge');
        if (!c.ok) {
          showError('Something went wrong. Try again.');
          return;
        }
        const { token, ts } = await c.json();

        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, token, ts, hp: hpInput.value }),
        });

        if (res.ok) {
          button.textContent = 'Thank you ✓';
          emailInput.value = '';
          status.textContent = 'You are in. Welcome.';
          status.classList.remove('error', 'hidden');
          status.classList.add('success');
        } else {
          const data = await res.json().catch(() => ({} as { error?: string }));
          showError(data?.error || 'Something went wrong. Try again.');
        }
      } catch {
        showError('Something went wrong. Try again.');
      }
    });
  }
  attachWritingNewsletter();
  document.addEventListener('astro:after-swap', attachWritingNewsletter);
</script>

<style>
  /* ============================================================
     /writing - J register chrome for the writing index.
     Founder-public register. Four sections + closing NOTA BENE.
     ============================================================*/

  /* ---- FIG I: numbered start-here items ---- */
  .writing-start {
    display: flex;
    flex-direction: column;
    margin-top: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    border: 1px solid var(--el-rule);
  }
  .writing-start-item {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 0.75rem + 1vw, 1.75rem);
    padding: clamp(1rem, 0.85rem + 0.6vw, 1.5rem) clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    border-bottom: 1px solid var(--el-rule);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease;
  }
  .writing-start-item:last-child { border-bottom: none; }
  .writing-start-item:hover { background: color-mix(in oklab, var(--el-accent) 4%, transparent); }
  .writing-start-number {
    font-family: var(--el-display);
    font-size: clamp(1.75rem, 1.25rem + 1.5vw, 2.25rem);
    font-weight: 400;
    color: var(--el-accent);
    line-height: 0.9;
    flex-shrink: 0;
    width: 2rem;
    text-align: center;
  }
  .writing-start-body { flex: 1; min-width: 0; }
  .writing-start-body h3 {
    font-family: var(--el-display);
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.15rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--el-text);
    margin: 0 0 0.35rem;
  }
  .writing-start-body p {
    font-family: var(--el-body);
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1rem);
    line-height: 1.55;
    color: var(--el-text-soft);
    margin: 0;
  }
  @media (max-width: 480px) {
    .writing-start-item { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .writing-start-number { width: auto; text-align: left; }
  }

  /* ---- FIG II: article list ---- */
  .writing-list {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);
    margin-top: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
  }
  .writing-card {
    display: block;
    padding: clamp(1.25rem, 1rem + 1vw, 1.75rem);
    border: 1px solid var(--el-rule);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .writing-card:hover {
    border-color: var(--el-accent);
    transform: translateY(-1px);
  }
  .writing-card h3 {
    font-family: var(--el-display);
    font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--el-text);
    margin: 0 0 0.65rem;
    line-height: 1.25;
  }
  .writing-card p {
    font-family: var(--el-body);
    font-size: clamp(0.95rem, 0.9rem + 0.25vw, 1.1rem);
    line-height: 1.55;
    color: var(--el-text-soft);
    margin: 0 0 0.85rem;
    max-width: 65ch;
  }
  .writing-card time {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
  }

  /* ---- FIG III: newsletter ---- */
  .writing-newsletter-form {
    max-width: 480px;
    margin-top: clamp(1rem, 0.85rem + 0.75vw, 1.5rem);
  }
  .writing-newsletter-row {
    display: flex;
    gap: 0.5rem;
    border-bottom: 1px solid var(--el-text);
    padding-bottom: 0.5rem;
  }
  .writing-newsletter-row input[type="email"] {
    flex: 1;
    padding: 0.45rem 0;
    background: transparent;
    border: none;
    font-family: var(--el-body);
    font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
    color: var(--el-text);
    min-width: 0;
  }
  .writing-newsletter-row input[type="email"]::placeholder {
    color: var(--el-text-quiet);
  }
  .writing-newsletter-row input[type="email"]:focus { outline: none; }
  .writing-newsletter-row button {
    padding: 0.45rem 0;
    background: transparent;
    color: var(--el-accent);
    border: none;
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
  }
  .writing-newsletter-row button:hover { color: var(--el-text); }
  .writing-newsletter-row button:disabled { opacity: 0.6; cursor: wait; }
  .writing-hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    z-index: -1;
  }
  .writing-newsletter-status {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 0.85rem;
    min-height: 1.2em;
    color: var(--el-text-quiet);
  }
  .writing-newsletter-status.hidden { display: none; }
  .writing-newsletter-status.success { color: var(--el-accent); }
  .writing-newsletter-status.error { color: #c44; }

  /* ---- NOTA BENE: elsewhere links ---- */
  .writing-elsewhere {
    display: flex;
    gap: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    flex-wrap: wrap;
    margin-top: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
  }
</style>
