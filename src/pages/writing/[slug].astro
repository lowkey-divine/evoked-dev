---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="container article">
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {post.data.tags && (
        <div class="tags">
          {post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="article-content">
      <Content />
    </div>

    <footer class="article-footer">
      <div class="newsletter-cta">
        <h3>Keep reading</h3>
        <p>Occasional updates on sovereignty, trust, and building something better.</p>
        <form id="newsletter-form" class="newsletter-form">
          <input type="email" id="newsletter-email" name="email" placeholder="your@email.com" required aria-label="Email address" />
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </form>
        <p id="newsletter-status" class="newsletter-status" aria-live="polite"></p>
      </div>
      <a href="/writing" class="back-link">← Back to Writing</a>
    </footer>
  </article>
</BaseLayout>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const status = document.getElementById('newsletter-status') as HTMLParagraphElement;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    status.textContent = '';
    const button = form.querySelector('button') as HTMLButtonElement;
    button.disabled = true;
    button.textContent = 'Subscribing...';

    try {
      const res = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        status.textContent = 'You are in. Welcome.';
        status.className = 'newsletter-status success';
        emailInput.value = '';
      } else {
        const data = await res.json();
        status.textContent = data.error || 'Something went wrong. Try again.';
        status.className = 'newsletter-status error';
      }
    } catch {
      status.textContent = 'Something went wrong. Try again.';
      status.className = 'newsletter-status error';
    } finally {
      button.disabled = false;
      button.textContent = 'Subscribe';
    }
  });
</script>

<style>
  .article {
    max-width: 700px;
    padding-top: var(--space-lg);
    padding-bottom: var(--space-lg);
  }

  .article-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border-subtle);
  }

  .article-header h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-sm);
    line-height: 1.2;
  }

  .article-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }

  .article-header time {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  .tag {
    padding: 0.2rem 0.6rem;
    background: var(--accent-subtle);
    color: var(--accent-warm);
    border-radius: 100px;
    font-size: 0.75rem;
    text-transform: lowercase;
  }

  .article-content {
    line-height: 1.8;
  }

  .article-content :global(h2) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    font-size: 1.6rem;
  }

  .article-content :global(h3) {
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
    font-size: 1.3rem;
  }

  .article-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-md);
  }

  .article-content :global(li) {
    margin-bottom: var(--space-xs);
    color: var(--text-secondary);
  }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--accent-warm);
    padding-left: var(--space-md);
    margin: var(--space-md) 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .article-content :global(code) {
    background: var(--bg-elevated);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .article-content :global(pre) {
    background: var(--bg-elevated);
    padding: var(--space-md);
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .article-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .article-content :global(a) {
    color: var(--accent-warm);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-content :global(a:hover) {
    color: var(--accent-glow);
  }

  .article-footer {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border-subtle);
  }

  .newsletter-cta {
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .newsletter-cta h3 {
    margin-bottom: var(--space-xs);
  }

  .newsletter-cta p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-xs);
    justify-content: center;
    flex-wrap: wrap;
    max-width: 400px;
    margin: var(--space-md) auto 0;
  }

  .newsletter-form input[type="email"] {
    flex: 1;
    min-width: 200px;
    padding: var(--space-sm) var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    color: var(--text-primary);
    font-size: 0.95rem;
    font-family: var(--font-body);
  }

  .newsletter-form input[type="email"]:focus {
    outline: none;
    border-color: var(--border-accent);
  }

  .newsletter-form input[type="email"]::placeholder {
    color: var(--text-muted);
  }

  .newsletter-status {
    font-size: 0.85rem;
    margin-top: var(--space-sm);
    min-height: 1.2em;
  }

  .newsletter-status.success {
    color: var(--accent-warm);
  }

  .newsletter-status.error {
    color: #e57373;
  }

  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent-warm);
  }

  @media (max-width: 600px) {
    .article-header h1 {
      font-size: 2rem;
    }
  }
</style>
