---
import { getCollection } from 'astro:content';
import ElevationLayout from '../../layouts/ElevationLayout.astro';
import SovereignLayout from '../../layouts/SovereignLayout.astro';
import August2Countdown from '../../components/August2Countdown.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => {
    return data.draft !== true;
  });
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const isSovereign = post.data.sovereign;

const articleStructuredData = [
  {
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    ...(post.data.updatedDate && { "dateModified": post.data.updatedDate.toISOString() }),
    "url": `https://evoked.dev/writing/${post.slug}`,
    "author": { "@id": "https://evoked.dev/#person" },
    "publisher": { "@id": "https://evoked.dev/#person" },
    ...(post.data.tags && { "keywords": post.data.tags.join(", ") }),
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://evoked.dev/" },
      { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://evoked.dev/writing/" },
      { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://evoked.dev/writing/${post.slug}/` },
    ],
  },
];

const articleMeta = {
  publishedTime: post.data.pubDate.toISOString(),
  author: "Erin Stanley",
};

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

{isSovereign ? (
  <SovereignLayout
    title={post.data.title}
    description={post.data.description}
    hideFloatingChat={true}
    structuredData={articleStructuredData}
    ogType="article"
    articleMeta={articleMeta}
  >
    <article class="container article">
      <header class="article-header">
        <h1>{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
        <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        {post.data.tags && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <a href={`/writing/tag/${tag}`} class="tag">{tag}</a>
            ))}
          </div>
        )}
      </header>
      {post.slug === 'the-august-2-question' && (
        <August2Countdown activateAtDays={8} />
      )}
      <div class="article-content">
        <Content />
      </div>
      <footer class="article-footer">
        <a href="/writing" class="back-link">&larr; Back to Writing</a>
      </footer>
    </article>
  </SovereignLayout>
) : (
  <ElevationLayout
    title={post.data.title}
    description={post.data.description}
    structuredData={articleStructuredData}
    ogType="article"
    articleMeta={articleMeta}
  >
    <article class="el-article">
      <header class="el-article-header">
        <p class="el-article-eyebrow">
          <span>Writing</span>
          <span class="el-article-pipe">·</span>
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        </p>
        <h1>{post.data.title}</h1>
        <p class="el-article-description">{post.data.description}</p>
        {post.data.tags && (
          <div class="el-article-tags">
            {post.data.tags.map((tag) => (
              <a href={`/writing/tag/${tag}`} class="el-article-tag">{tag}</a>
            ))}
          </div>
        )}
      </header>

      {post.slug === 'the-august-2-question' && (
        <August2Countdown activateAtDays={8} />
      )}

      <div class="el-article-content">
        <Content />
      </div>

      <footer class="el-article-footer">
        <div class="el-article-newsletter">
          <p class="el-article-newsletter-label">Keep reading</p>
          <h3>Letters about the Standard, the practice, and what we are building.</h3>
          <p class="el-article-newsletter-blurb">Sent when there is something worth sending. Not often.</p>
          <form id="newsletter-form" class="el-article-newsletter-form" novalidate>
            <div class="el-article-newsletter-row">
              <input type="email" id="newsletter-email" name="email" placeholder="your.email@example.com" required aria-label="Email address" />
              <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" class="el-hp-field" />
              <button type="submit">Subscribe</button>
            </div>
          </form>
          <p id="newsletter-status" class="el-newsletter-status hidden" aria-live="polite"></p>
        </div>
        <a href="/writing" class="el-back-link">&larr; Back to Writing</a>
      </footer>
    </article>
  </ElevationLayout>
)}

<script>
  function attachArticleNewsletter() {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    if (!form || form.dataset.wired === 'true') return;
    form.dataset.wired = 'true';

    const status = document.getElementById('newsletter-status') as HTMLParagraphElement | null;
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    const hpInput = form.querySelector('input[name="website"]') as HTMLInputElement;
    const button = form.querySelector('button') as HTMLButtonElement;

    const showError = (msg: string) => {
      button.disabled = false;
      button.textContent = 'Subscribe';
      if (status) {
        status.textContent = msg;
        status.classList.remove('hidden', 'success');
        status.classList.add('error');
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;

      if (hpInput?.value) {
        button.textContent = 'Thank you ✓';
        emailInput.value = '';
        return;
      }

      button.disabled = true;
      button.textContent = 'Subscribing...';
      if (status) {
        status.textContent = '';
        status.classList.remove('error', 'success', 'hidden');
      }

      try {
        const c = await fetch('/api/newsletter/challenge');
        if (!c.ok) {
          showError('Something went wrong. Try again.');
          return;
        }
        const { token, ts } = await c.json();

        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, token, ts, hp: hpInput?.value || '' }),
        });

        if (res.ok) {
          button.textContent = 'Thank you ✓';
          emailInput.value = '';
          if (status) {
            status.textContent = 'You are in. Welcome.';
            status.classList.remove('error', 'hidden');
            status.classList.add('success');
          }
        } else {
          const data = await res.json().catch(() => ({} as { error?: string }));
          showError(data?.error || 'Something went wrong. Try again.');
        }
      } catch {
        showError('Something went wrong. Try again.');
      }
    });
  }
  attachArticleNewsletter();
  document.addEventListener('astro:after-swap', attachArticleNewsletter);
</script>

<style>
  /* ============================================================
     /writing/[slug] - article reading surface in J chrome.
     The article body keeps generous reading typography (EB Garamond,
     1.75 line-height) so prose stays readable. Section headings inside
     the article are sentence case display serif (not the founder-public
     UPPERCASE Syncopate that would feel shouty mid-essay).
     Sovereign-flagged articles continue to use SovereignLayout
     untouched.
     ============================================================*/

  .el-article {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2rem, 1.5rem + 2vw, 4rem) var(--el-content-pad)
            clamp(3rem, 2rem + 3vw, 5rem);
  }

  /* ---- Article header ---- */
  .el-article-header {
    margin-bottom: clamp(2.5rem, 2rem + 2vw, 4rem);
    padding-bottom: clamp(1.5rem, 1rem + 1vw, 2.25rem);
    border-bottom: 1px solid var(--el-rule);
  }
  .el-article-eyebrow {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-accent);
    margin: 0 0 clamp(1.25rem, 1rem + 1vw, 2rem);
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }
  .el-article-eyebrow time {
    color: var(--el-text-quiet);
    font-variant-numeric: tabular-nums;
  }
  .el-article-pipe {
    color: var(--el-text-quiet);
    font-weight: 400;
  }
  .el-article :global(.el-article-header h1) {
    font-family: var(--el-display);
    font-size: clamp(2rem, 1.5rem + 2.5vw, 3.25rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    color: var(--el-text);
    margin: 0 0 clamp(1rem, 0.85rem + 0.75vw, 1.5rem);
    overflow-wrap: break-word;
  }
  .el-article-description {
    font-family: var(--el-body);
    font-style: italic;
    font-size: clamp(1.1rem, 1.05rem + 0.4vw, 1.35rem);
    line-height: 1.45;
    color: var(--el-text-soft);
    margin: 0;
    max-width: 60ch;
  }
  .el-article-tags {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
  }
  .el-article-tag {
    font-family: var(--el-ui);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--el-accent);
    border: 1px solid var(--el-rule);
    padding: 3px 9px;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .el-article-tag:hover {
    border-color: var(--el-accent);
    color: var(--el-text);
  }

  /* ---- Article body (rendered markdown) ---- */
  .el-article-content {
    font-family: var(--el-body);
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem);
    line-height: 1.75;
    color: var(--el-text-deep);
  }
  .el-article-content :global(p) {
    margin: 0 0 1.5rem;
    max-width: 65ch;
    color: var(--el-text-deep);
  }
  /* H2 = major section / intro - larger, upright, more presence */
  .el-article-content :global(h2) {
    font-family: var(--el-display);
    font-style: normal;
    font-size: clamp(1.75rem, 1.4rem + 1.4vw, 2.4rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--el-text-deep);
    margin: clamp(3rem, 2.25rem + 2vw, 4rem) 0 1.1rem;
    text-transform: none;
  }
  /* H3 = sub-section break - smaller, italic, clearly differentiated from H2 */
  .el-article-content :global(h3) {
    font-family: var(--el-display);
    font-style: italic;
    font-size: clamp(1.2rem, 1.05rem + 0.7vw, 1.55rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--el-text-deep);
    margin: clamp(2.25rem, 1.75rem + 1.25vw, 2.75rem) 0 0.85rem;
    text-transform: none;
  }
  .el-article-content :global(h4) {
    font-family: var(--el-ui);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-accent);
    margin: clamp(1.75rem, 1.25rem + 1vw, 2.25rem) 0 0.75rem;
  }
  .el-article-content :global(ul),
  .el-article-content :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
    max-width: 65ch;
  }
  .el-article-content :global(li) {
    margin-bottom: 0.5rem;
    color: var(--el-text-deep);
    line-height: 1.65;
  }
  .el-article-content :global(li > p) {
    margin-bottom: 0.75rem;
  }
  .el-article-content :global(blockquote) {
    margin: clamp(1.5rem, 1rem + 1vw, 2rem) 0;
    padding: 0.5rem 0 0.5rem 1.5rem;
    border-left: 2px solid var(--el-accent);
    font-style: italic;
    color: var(--el-text-soft);
    max-width: 60ch;
  }
  .el-article-content :global(blockquote p) {
    margin-bottom: 1rem;
  }
  .el-article-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  .el-article-content :global(a) {
    color: var(--el-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--el-rule);
    transition: border-color 0.2s ease;
  }
  .el-article-content :global(a:hover) {
    border-color: var(--el-accent);
    color: var(--el-text);
  }
  .el-article-content :global(strong) {
    font-weight: 500;
    color: var(--el-text-deep);
  }
  .el-article-content :global(em) {
    font-style: italic;
  }
  .el-article-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--el-rule);
    margin: clamp(2.5rem, 2rem + 1.5vw, 3.5rem) 0;
    max-width: 65ch;
  }
  .el-article-content :global(code) {
    background: color-mix(in oklab, var(--el-accent) 8%, transparent);
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
    font-size: 0.9em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
  .el-article-content :global(pre) {
    background: color-mix(in oklab, var(--el-text) 5%, transparent);
    padding: 1.25rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 0 0 1.5rem;
    max-width: 65ch;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .el-article-content :global(pre code) {
    background: none;
    padding: 0;
  }
  .el-article-content :global(img) {
    max-width: 100%;
    height: auto;
    margin: clamp(1.5rem, 1rem + 1vw, 2rem) 0;
  }

  /* ---- Article footer: newsletter CTA + back link ---- */
  .el-article-footer {
    margin-top: clamp(3rem, 2.5rem + 2vw, 4.5rem);
    padding-top: clamp(2rem, 1.5rem + 1.5vw, 3rem);
    border-top: 1px solid var(--el-rule);
  }
  .el-article-newsletter {
    margin-bottom: clamp(2.5rem, 2rem + 1.5vw, 3.5rem);
  }
  .el-article-newsletter-label {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-accent);
    margin: 0 0 1rem;
  }
  .el-article-newsletter h3 {
    font-family: var(--el-display);
    font-size: clamp(1.15rem, 1.05rem + 0.4vw, 1.4rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--el-text);
    margin: 0 0 0.85rem;
    letter-spacing: 0.01em;
    text-transform: none;
    max-width: 48ch;
  }
  .el-article-newsletter-blurb {
    font-family: var(--el-body);
    font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.05rem);
    line-height: 1.55;
    color: var(--el-text-soft);
    margin: 0 0 1.5rem;
    max-width: 48ch;
  }
  .el-article-newsletter-form {
    max-width: 440px;
  }
  .el-article-newsletter-row {
    display: flex;
    gap: 0.5rem;
    border-bottom: 1px solid var(--el-text);
    padding-bottom: 0.5rem;
  }
  .el-article-newsletter-row input[type="email"] {
    flex: 1;
    padding: 0.45rem 0;
    background: transparent;
    border: none;
    font-family: var(--el-body);
    font-size: clamp(1rem, 0.95rem + 0.2vw, 1.05rem);
    color: var(--el-text);
    min-width: 0;
  }
  .el-article-newsletter-row input[type="email"]::placeholder {
    color: var(--el-text-quiet);
  }
  .el-article-newsletter-row input[type="email"]:focus { outline: none; }
  .el-article-newsletter-row button {
    padding: 0.45rem 0;
    background: transparent;
    color: var(--el-accent);
    border: none;
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
  }
  .el-article-newsletter-row button:hover { color: var(--el-text); }
  .el-article-newsletter-row button:disabled { opacity: 0.6; cursor: wait; }
  .el-hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    z-index: -1;
  }
  .el-newsletter-status {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 0.85rem;
    min-height: 1.2em;
    color: var(--el-text-quiet);
  }
  .el-newsletter-status.hidden { display: none; }
  .el-newsletter-status.success { color: var(--el-accent); }
  .el-newsletter-status.error { color: #c44; }

  .el-back-link {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .el-back-link:hover { color: var(--el-accent); }

  /* ---- SovereignLayout fallback styles (unchanged) ---- */
  .article {
    max-width: 700px;
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }
  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-subtle);
  }
  .article-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .article-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 0.85rem;
  }
  .article-header time {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.85rem;
  }
  .tag {
    padding: 0.2rem 0.6rem;
    background: var(--accent-subtle);
    color: var(--accent-warm);
    border-radius: 100px;
    font-size: 0.75rem;
    text-transform: lowercase;
    text-decoration: none;
  }
  .article-content {
    line-height: 1.8;
  }
  .article-footer {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
  }
  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .back-link:hover { color: var(--accent-warm); }
</style>
