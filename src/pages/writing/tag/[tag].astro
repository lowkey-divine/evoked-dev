---
import { getCollection } from 'astro:content';
import ElevationLayout from '../../../layouts/ElevationLayout.astro';
import Hero from '../../../components/elevation/Hero.astro';
import Section from '../../../components/elevation/Section.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('writing', ({ data }) => !data.draft);
  const tagMap = new Map<string, typeof allPosts>();

  for (const post of allPosts) {
    if (post.data.tags) {
      for (const tag of post.data.tags) {
        const existing = tagMap.get(tag) || [];
        existing.push(post);
        tagMap.set(tag, existing);
      }
    }
  }

  return Array.from(tagMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const displayTag = tag.replace(/-/g, ' ');
const countLine = `${posts.length} article${posts.length !== 1 ? 's' : ''}`;
---

<ElevationLayout
  title={`Articles tagged "${displayTag}"`}
  description={`All articles on evoked.dev tagged with "${displayTag}" - writing on AI agent governance, sovereignty, and trust architecture.`}
>
  <Hero
    eyebrowParts={["Writing", "Tag"]}
    headline={displayTag}
    metaphor={[countLine]}
  />

  <Section marker="FIG · I" heading="Articles">
    <div class="writing-tag-list">
      {posts.map((post) => (
        <a href={`/writing/${post.slug}`} class="writing-tag-card">
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </a>
      ))}
    </div>
  </Section>

  <Section marker="NOTA · BENE" heading="Back to writing" closing={true}>
    <p class="lede">
      <a class="cta cta-secondary" href="/writing">All writing &rarr;</a>
    </p>
  </Section>
</ElevationLayout>

<style>
  .writing-tag-list {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);
    margin-top: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
  }
  .writing-tag-card {
    display: block;
    padding: clamp(1.25rem, 1rem + 1vw, 1.75rem);
    border: 1px solid var(--el-rule);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .writing-tag-card:hover {
    border-color: var(--el-accent);
    transform: translateY(-1px);
  }
  .writing-tag-card h3 {
    font-family: var(--el-display);
    font-size: clamp(1.1rem, 1rem + 0.5vw, 1.35rem);
    font-weight: 400;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--el-text);
    margin: 0 0 0.65rem;
    line-height: 1.25;
  }
  .writing-tag-card p {
    font-family: var(--el-body);
    font-size: clamp(0.95rem, 0.9rem + 0.25vw, 1.1rem);
    line-height: 1.55;
    color: var(--el-text-soft);
    margin: 0 0 0.85rem;
    max-width: 65ch;
  }
  .writing-tag-card time {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
  }
</style>
