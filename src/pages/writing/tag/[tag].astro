---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('writing', ({ data }) => !data.draft);
  const tagMap = new Map<string, typeof allPosts>();

  for (const post of allPosts) {
    if (post.data.tags) {
      for (const tag of post.data.tags) {
        const existing = tagMap.get(tag) || [];
        existing.push(post);
        tagMap.set(tag, existing);
      }
    }
  }

  return Array.from(tagMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const displayTag = tag.replace(/-/g, ' ');
---

<BaseLayout title={`Articles tagged "${displayTag}"`} description={`All articles on evoked.dev tagged with "${displayTag}" - writing on AI agent governance, sovereignty, and trust architecture.`}>
  <div class="hero">
    <h1>Tag: {displayTag}</h1>
    <p class="tagline">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
  </div>

  <section class="container">
    <div class="article-list">
      {posts.map((post) => (
        <a href={`/writing/${post.slug}`} class="article-card">
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </a>
      ))}
    </div>
  </section>

  <section class="container">
    <a href="/writing" class="back-link">&larr; Back to all writing</a>
  </section>
</BaseLayout>

<style>
  .article-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .article-card {
    display: block;
    padding: var(--space-md);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    text-decoration: none;
    transition: all var(--transition-smooth);
  }

  .article-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  .article-card h3 {
    margin: 0 0 var(--space-xs) 0;
    color: var(--text-primary);
    font-size: 1.3rem;
  }

  .article-card p {
    margin: 0 0 var(--space-sm) 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .article-card time {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent-warm);
  }
</style>
