---
import ElevationLayout from '../layouts/ElevationLayout.astro';
import Hero from '../components/elevation/Hero.astro';
import Section from '../components/elevation/Section.astro';
---

{/*
  Voice register: care-oriented, sister-shape to /projects/ezri and
  /kitchen-table. Intimate-domestic-leaning - the page is linked from
  /projects/ezri's "Here are some places to find support" footer. The
  em-dash on line "Call or text 988 — available 24/7" is preserved as
  register-correct per the Voice Discipline Scope addendum.
*/}

<ElevationLayout
  title="Resources"
  description="Places to find support when you need it."
>
  <Hero
    headline="Resources."
    metaphor={["Places to find support."]}
    sub="Inner work can surface things that are tender or difficult. If you need support, these are good places to start."
  />

  <Section marker="FIG · I" heading="Crisis support">
    <p class="lede">If you're in immediate distress, please reach out:</p>
    <ul class="resource-list">
      <li>
        <strong>988 Suicide &amp; Crisis Lifeline</strong> (US)<br />
        Call or text <a href="tel:988">988</a> — available 24/7
      </li>
      <li>
        <strong>Crisis Text Line</strong><br />
        Text <strong>HOME</strong> to <a href="sms:741741">741741</a>
      </li>
      <li>
        <strong>International Association for Suicide Prevention</strong><br />
        <a href="https://www.iasp.info/resources/Crisis_Centres/" target="_blank" rel="noopener">Find a crisis center in your country</a>
      </li>
    </ul>
  </Section>

  <Section marker="FIG · II" heading="Finding a therapist">
    <p class="lede">If you're looking for ongoing professional support:</p>
    <ul class="resource-list">
      <li>
        <strong>Psychology Today Therapist Finder</strong><br />
        <a href="https://www.psychologytoday.com/us/therapists" target="_blank" rel="noopener">Search by location, specialty, and insurance</a>
      </li>
      <li>
        <strong>Open Path Collective</strong><br />
        <a href="https://openpathcollective.org/" target="_blank" rel="noopener">Affordable therapy ($30-$80/session)</a>
      </li>
      <li>
        <strong>Inclusive Therapists</strong><br />
        <a href="https://www.inclusivetherapists.com/" target="_blank" rel="noopener">Directory centered on marginalized communities</a>
      </li>
    </ul>
  </Section>

  <Section marker="FIG · III" heading="Peer support">
    <p class="lede">Sometimes you just need to talk to someone who understands:</p>
    <ul class="resource-list">
      <li>
        <strong>Warmlines</strong> (non-crisis support)<br />
        <a href="https://warmline.org/warmdir.html" target="_blank" rel="noopener">Find a warmline in your state</a>
      </li>
      <li>
        <strong>7 Cups</strong><br />
        <a href="https://www.7cups.com/" target="_blank" rel="noopener">Free online chat with trained listeners</a>
      </li>
    </ul>
  </Section>

  <Section marker="NOTA · BENE" closing={true}>
    <p class="resources-close">Reaching out is not weakness. It's wisdom.</p>
  </Section>
</ElevationLayout>

<style>
  /* Resource list - brass-left-rule items, gentle reading typography
     matching the intimate-domestic register of /ezri + /kitchen-table. */
  .resource-list {
    list-style: none;
    padding: 0;
    margin: clamp(1.25rem, 1rem + 0.75vw, 1.75rem) 0 0;
  }
  .resource-list li {
    padding: 0.85rem 0 0.85rem 1.5rem;
    border-left: 2px solid var(--el-accent);
    margin-bottom: clamp(1rem, 0.85rem + 0.5vw, 1.25rem);
    font-family: var(--el-body);
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.1rem);
    line-height: 1.7;
    color: var(--el-text-soft);
    max-width: 60ch;
  }
  .resource-list li:last-child { margin-bottom: 0; }
  .resource-list li strong {
    color: var(--el-text-deep);
    display: inline;
    font-weight: 500;
  }
  .resource-list a {
    color: var(--el-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--el-rule);
  }
  .resource-list a:hover {
    color: var(--el-text-deep);
    border-color: var(--el-accent);
  }

  .resources-close {
    font-family: var(--el-body);
    font-style: italic;
    font-size: clamp(1.15rem, 1.05rem + 0.5vw, 1.4rem);
    line-height: 1.5;
    color: var(--el-text-deep);
    text-align: center;
    margin: 0;
    max-width: 36ch;
    margin-left: auto;
    margin-right: auto;
  }
</style>
