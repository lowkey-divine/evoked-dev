---
import ElevationLayout from '../layouts/ElevationLayout.astro';
import Hero from '../components/elevation/Hero.astro';
import Section from '../components/elevation/Section.astro';

export const prerender = false;
---

<ElevationLayout
  title="Tell us about your system"
  description="Help us understand where you are so we can prepare for a real conversation. No pitch. No pressure."
>
  <Hero
    eyebrowParts={["Engage", "Consulting"]}
    headline="Tell us about your system."
    sub="We read every submission personally. This helps us prepare for a real conversation - not a pitch."
  />

  <section class="intake-section">
    <form id="consulting-form" class="intake-form" novalidate>

      <div class="step active" data-step="1">
        <p class="step-label">The foundation</p>
        <label for="ci-foundation">What does your current AI or agent system look like?</label>
        <textarea id="ci-foundation" name="foundation" rows="4" required placeholder="What are you running? How many agents, what do they do, how long have they been in production?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="2">
        <p class="step-label">The walls</p>
        <label for="ci-walls">Where is it cracking?</label>
        <textarea id="ci-walls" name="walls" rows="4" placeholder="What's breaking, drifting, or keeping you up at night? What prompted you to look for help now?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="3">
        <p class="step-label">The windows</p>
        <label for="ci-windows">What do you need the outside world to see?</label>
        <textarea id="ci-windows" name="windows" rows="4" placeholder="Compliance, trust signals, customer-facing transparency? What's the external pressure?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="4">
        <p class="step-label">The roof</p>
        <label for="ci-roof">What would "solved" look like for you?</label>
        <textarea id="ci-roof" name="roof" rows="4" placeholder="If this engagement went perfectly, what's different in six months?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="5">
        <p class="step-label">You</p>
        <label for="ci-name">Your name</label>
        <input type="text" id="ci-name" name="name" required />
        <label for="ci-email" class="mt-md">Your email</label>
        <input type="email" id="ci-email" name="email" required />
        <label for="ci-org" class="mt-md">Organization <span class="optional">(optional)</span></label>
        <input type="text" id="ci-org" name="org" />
        <button type="submit" class="step-submit mt-md">Send it over</button>
        <p id="ci-status" class="form-status" aria-live="polite"></p>
      </div>

      <div class="step-progress" aria-hidden="true">
        <span class="progress-dot active" data-for="1"></span>
        <span class="progress-dot" data-for="2"></span>
        <span class="progress-dot" data-for="3"></span>
        <span class="progress-dot" data-for="4"></span>
        <span class="progress-dot" data-for="5"></span>
      </div>

      <button type="button" class="step-back" id="step-back" style="display:none;">Back</button>
    </form>
  </section>

  <Section marker="NOTA · BENE" heading="What happens next" closing={true}>
    <p class="lede">
      I read every submission personally. If there is a fit, I will reach out
      within a few days with a scope conversation. We start with what's real -
      not a sales deck.
    </p>
    <p class="intake-fineprint">
      What you write here goes to Erin's inbox and is used to schedule one call.
      Nothing else. Minimal site analytics via Vercel (pageview only, no cookies,
      no profile). No marketing trackers, no list, no profile sold or shared. If
      we don't end up working together, Erin deletes your message within 30 days.
      How we treat your data is named at our
      <a href="/pledge">pledge</a> and at our
      <a href="/legal/privacy">privacy policy</a>.
    </p>
  </Section>
</ElevationLayout>

<script>
  function attachConsultingIntake() {
    const form = document.getElementById('consulting-form') as HTMLFormElement | null;
    if (!form || form.dataset.wired === 'true') return;
    form.dataset.wired = 'true';

    const status = document.getElementById('ci-status') as HTMLParagraphElement;
    const steps = form.querySelectorAll('.step') as NodeListOf<HTMLElement>;
    const dots = form.querySelectorAll('.progress-dot') as NodeListOf<HTMLElement>;
    const backBtn = document.getElementById('step-back') as HTMLButtonElement;
    let current = 1;
    const formLoadedAt = Date.now();

    function showStep(n: number) {
      steps.forEach(s => s.classList.remove('active'));
      dots.forEach(d => d.classList.remove('active'));
      const step = form!.querySelector(`[data-step="${n}"]`) as HTMLElement;
      const dot = form!.querySelector(`.progress-dot[data-for="${n}"]`) as HTMLElement;
      if (step) step.classList.add('active');
      if (dot) dot.classList.add('active');

      dots.forEach(d => {
        const forStep = parseInt(d.getAttribute('data-for') || '0');
        if (forStep < n) d.classList.add('completed');
        else d.classList.remove('completed');
      });

      backBtn.style.display = n > 1 ? 'block' : 'none';
      current = n;

      const firstInput = step?.querySelector('input, textarea') as HTMLElement;
      if (firstInput) setTimeout(() => firstInput.focus(), 100);
    }

    form.querySelectorAll('.step-next').forEach(btn => {
      btn.addEventListener('click', () => {
        const step = (btn as HTMLElement).closest('.step') as HTMLElement;
        const required = step.querySelectorAll('[required]') as NodeListOf<HTMLInputElement | HTMLTextAreaElement>;
        let valid = true;
        required.forEach(input => { if (!input.value.trim()) valid = false; });
        if (valid) {
          const stepNum = parseInt(step.getAttribute('data-step') || '1');
          showStep(stepNum + 1);
        }
      });
    });

    backBtn.addEventListener('click', () => { if (current > 1) showStep(current - 1); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';

      const name = (document.getElementById('ci-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('ci-email') as HTMLInputElement).value.trim();
      const org = (document.getElementById('ci-org') as HTMLInputElement).value.trim();
      const foundation = (document.getElementById('ci-foundation') as HTMLTextAreaElement).value.trim();
      const walls = (document.getElementById('ci-walls') as HTMLTextAreaElement).value.trim();
      const windows = (document.getElementById('ci-windows') as HTMLTextAreaElement).value.trim();
      const roof = (document.getElementById('ci-roof') as HTMLTextAreaElement).value.trim();

      if (!name || !email || !foundation) return;

      const button = form!.querySelector('[type="submit"]') as HTMLButtonElement;
      button.disabled = true;
      button.textContent = 'Sending...';

      try {
        const c = await fetch('/api/form/challenge');
        if (!c.ok) throw new Error('failed');
        const { token, ts } = await c.json();

        const res = await fetch('/api/consulting-intake', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, org, foundation, walls, windows, roof, token, ts, hp: '', formLoadedAt }),
        });

        if (res.ok) {
          status.textContent = 'Received. I will be in touch.';
          status.className = 'form-status success';
          form!.reset();
          steps.forEach(s => s.classList.remove('active'));
          dots.forEach(d => { d.classList.add('completed'); d.classList.remove('active'); });
          backBtn.style.display = 'none';
        } else {
          const resData = await res.json();
          status.textContent = resData.error || 'Something went wrong. Try again.';
          status.className = 'form-status error';
        }
      } catch {
        status.textContent = 'Something went wrong. Try again.';
        status.className = 'form-status error';
      } finally {
        button.disabled = false;
        button.textContent = 'Send it over';
      }
    });
  }
  attachConsultingIntake();
  document.addEventListener('astro:after-swap', attachConsultingIntake);
</script>

<style>
  /* /consulting-intake - founder-public register, five-step
     architecture-anatomy form (foundation / walls / windows /
     roof / you) in J chrome. Same form pattern as /build-with-us
     and /coaching-intake. NOTA BENE close carries the privacy
     disclosure as fineprint linking to /pledge and /legal/privacy. */

  .intake-section {
    padding: clamp(2rem, 1.5rem + 2vw, 4rem) 0
            clamp(3rem, 2rem + 3vw, 5rem);
    border-top: 1px solid var(--el-rule);
  }
  .intake-form {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
  }
  .step { display: none; }
  .step.active {
    display: block;
    animation: intake-fade-in 0.32s ease;
  }
  @keyframes intake-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .step-label {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--el-accent);
    margin: 0 0 clamp(1rem, 0.75rem + 0.75vw, 1.5rem);
  }

  .step label:not(.optional) {
    display: block;
    font-family: var(--el-display);
    font-size: clamp(1.05rem, 1rem + 0.4vw, 1.3rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.005em;
    color: var(--el-text);
    margin-bottom: clamp(0.75rem, 0.6rem + 0.4vw, 1rem);
  }
  /* Contact-step subsequent labels (email, organization) render
     as ui small-caps for visual balance against the display-serif
     primary label. */
  .step label:not(:first-of-type) {
    font-family: var(--el-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
    margin-bottom: 0.4rem;
  }

  .optional {
    font-family: var(--el-body);
    font-size: 11px;
    color: var(--el-text-quiet);
    font-style: italic;
    letter-spacing: 0;
    text-transform: none;
    margin-left: 0.35rem;
  }

  .step input[type="text"],
  .step input[type="email"],
  .step textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--el-rule);
    background: transparent;
    color: var(--el-text);
    font-family: var(--el-body);
    font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
    line-height: 1.55;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .step input:focus,
  .step textarea:focus {
    outline: none;
    border-color: var(--el-accent);
    box-shadow: 0 0 0 1px var(--el-accent);
  }
  .step input::placeholder,
  .step textarea::placeholder { color: var(--el-text-quiet); }
  .step textarea { resize: vertical; }

  .step-next,
  .step-submit {
    margin-top: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    padding: 0.6rem 1.6rem;
    background: transparent;
    color: var(--el-accent);
    border: 1px solid var(--el-accent);
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .step-next:hover,
  .step-submit:hover {
    background: var(--el-accent);
    color: var(--el-bg);
  }
  .step-submit:disabled { opacity: 0.55; cursor: wait; }

  .mt-md { margin-top: clamp(0.85rem, 0.7rem + 0.4vw, 1.2rem); }

  .step-progress {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-top: clamp(2rem, 1.5rem + 1.5vw, 3rem);
  }
  .progress-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--el-rule);
    transition: background 0.2s ease, opacity 0.2s ease;
  }
  .progress-dot.active { background: var(--el-accent); }
  .progress-dot.completed { background: var(--el-accent); opacity: 0.4; }

  .step-back {
    display: block;
    margin: 0.85rem auto 0;
    background: none;
    border: none;
    color: var(--el-text-quiet);
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0.5rem 1rem;
  }
  .step-back:hover { color: var(--el-text-soft); }

  .form-status {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 1rem;
    min-height: 1.2em;
    color: var(--el-text-quiet);
  }
  .form-status.success { color: var(--el-accent); }
  .form-status.error   { color: #c44; }

  /* NOTA BENE fineprint - privacy disclosure */
  .intake-fineprint {
    font-family: var(--el-body);
    font-size: clamp(0.85rem, 0.8rem + 0.2vw, 0.95rem);
    line-height: 1.65;
    color: var(--el-text-quiet);
    margin-top: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    max-width: 65ch;
  }
  .intake-fineprint a {
    color: var(--el-text-soft);
    text-decoration: none;
    border-bottom: 1px solid var(--el-rule);
  }
  .intake-fineprint a:hover {
    color: var(--el-accent);
    border-color: var(--el-accent);
  }
</style>
