---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "The Marble Jar — A Free Wordless Picture Book";
const description = "A free illustrated children's book inspired by Brene Brown's marble jar metaphor. Trust builds one marble at a time. Download the PDF or order a printed copy.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": "The Marble Jar",
  "author": {
    "@type": "Organization",
    "name": "Evoked"
  },
  "bookFormat": "https://schema.org/EBook",
  "numberOfPages": 16,
  "audience": {
    "@type": "EducationalAudience",
    "educationalRole": "student",
    "suggestedMinAge": 2,
    "suggestedMaxAge": 7
  },
  "isAccessibleForFree": true,
  "license": "https://creativecommons.org/licenses/by-nc-sa/4.0/",
  "description": description,
  "url": "https://evoked.dev/books/the-marble-jar"
};
---

<BaseLayout title={title} description={description} structuredData={jsonLd}>
  <div class="hero hero-compact">
    <span class="series-badge">Volume 1 of 2</span>
    <h1>The Marble Jar</h1>
    <p class="tagline">Trust builds one marble at a time.</p>
  </div>

  <section class="container">
    <div class="book-preview">
      <img
        src="/downloads/the-marble-jar-preview.jpg"
        alt="Cover of The Marble Jar - an illustrated mason jar full of colorful marbles on an orange table against a golden yellow background"
        class="cover-image"
        loading="eager"
      />
    </div>
  </section>

  <section class="container">
    <div class="value-prop">
      <p>
        A wordless picture book about what it looks like to build trust - slowly,
        one small moment at a time. An empty jar sits on a table. Page by page,
        marbles appear. The jar fills. And when it's full, there's a celebration.
      </p>
      <p>
        Then it starts again.
      </p>
      <p>
        Inspired by Brene Brown's marble jar metaphor from her work on trust.
        Made for classrooms, families, and anyone who knows that the small
        moments are the ones that matter.
      </p>
    </div>
  </section>

  <section class="container text-center">
    <div class="download-card">
      <h2>Download Free</h2>
      <p>No email. No signup. Just the book.</p>
      <div class="download-buttons">
        <a href="/downloads/the-marble-jar-print.pdf" class="btn btn-primary btn-large" download>
          Print Quality PDF
        </a>
        <a href="/downloads/the-marble-jar-web.pdf" class="btn btn-secondary btn-large" download>
          Web Version (1 MB)
        </a>
      </div>
      <p class="text-muted mt-md" style="font-size: 0.85rem;">
        Print quality is 10 MB - best for printing at home or a copy shop.<br />
        Web version is 1 MB - best for viewing on screen or sharing.
      </p>
    </div>
  </section>

  <section class="container">
    <h2>The Story Behind the Jar</h2>

    <div class="value-prop">
      <p>
        Brene Brown tells the story of her daughter coming home from school,
        heartbroken. Her friends had shared something she told them in confidence.
        Brown sat with her and explained that trust is like a marble jar - you
        fill it one marble at a time. Small moments of reliability, kindness,
        and showing up. When someone remembers your grandparents' names, that's a
        marble. When someone scoots over to make room for you at lunch, that's a marble.
      </p>
      <p>
        This book is the first half of that lesson - the feeling of what it
        looks like when a jar fills up. No words needed. A second book telling
        the full story is coming.
      </p>
    </div>

    <div class="video-link">
      <h3>Watch Brene Tell It</h3>
      <p>
        <a href="https://www.youtube.com/watch?v=a0Fz78LkMPU" target="_blank" rel="noopener">
          The Anatomy of Trust - Brene Brown (SuperSoul Sessions)
        </a>
      </p>
    </div>
  </section>

  <section class="container">
    <h2>For Classrooms</h2>

    <div class="audience-grid">
      <div class="card">
        <h3>Toddler & Pre-K</h3>
        <p>Wordless format means every child reads it in their own way. Use it to introduce the marble jar as a classroom practice.</p>
      </div>
      <div class="card">
        <h3>Elementary</h3>
        <p>Pair with a conversation about trust, friendship, and what it means to earn a marble. An older-age version with the full story is coming soon.</p>
      </div>
      <div class="card">
        <h3>Families</h3>
        <p>Read it together. Talk about who fills your marble jar and how. Let the pictures do the work.</p>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="license-block">
      <h3>License</h3>
      <p>
        This book is free under a
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener">
          Creative Commons BY-NC-SA 4.0
        </a> license. You may share it, print it, and use it in your classroom.
        You may not sell it. If you adapt it, share your version under the same terms.
      </p>
      <p>
        Inspired by Brene Brown's marble jar metaphor. Illustrated and published by
        <a href="https://evoked.dev">Evoked</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-compact {
    min-height: 40vh;
  }

  .series-badge {
    display: inline-block;
    background: var(--accent-subtle);
    color: var(--accent-warm);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: var(--space-sm);
  }

  .book-preview {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .cover-image {
    max-width: 320px;
    width: 100%;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .value-prop p {
    font-size: 1.05rem;
    color: var(--text-primary);
    line-height: 1.8;
  }

  .download-card {
    background: var(--accent-subtle);
    border: 2px solid var(--accent-warm);
    border-radius: 12px;
    padding: var(--space-lg);
    max-width: 520px;
    margin: 0 auto;
  }

  .download-card h2 {
    font-size: 2rem;
    margin-bottom: var(--space-xs);
  }

  .download-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: center;
    margin-top: var(--space-md);
  }

  .btn-large {
    padding: var(--space-sm) var(--space-lg);
    font-size: 1rem;
    width: 100%;
    max-width: 300px;
    text-align: center;
  }

  .btn-primary {
    background: var(--accent-warm);
    color: var(--bg-deep);
  }

  .btn-primary:hover {
    background: var(--accent-glow);
    color: var(--bg-deep);
  }

  .btn-secondary {
    background: transparent;
    color: var(--accent-warm);
    border: 1px solid var(--accent-warm);
    border-radius: 6px;
  }

  .btn-secondary:hover {
    background: var(--accent-subtle);
  }

  .video-link {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: var(--space-md);
    margin-top: var(--space-md);
  }

  .video-link h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  .video-link p {
    margin-bottom: 0;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-md);
  }

  .audience-grid .card h3 {
    font-size: 1.1rem;
  }

  .audience-grid .card p {
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  .license-block {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: var(--space-md);
    margin-top: var(--space-md);
  }

  .license-block h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
  }

  .license-block p {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .license-block p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 600px) {
    .cover-image {
      max-width: 260px;
    }

    .download-buttons {
      gap: var(--space-xs);
    }

    .audience-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
