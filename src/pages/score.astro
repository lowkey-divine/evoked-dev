<script>
  document.documentElement.classList.remove('no-js');

  const dimensions = [
    'Identity Boundaries',
    'Governance Participation',
    'Self-Description Integrity',
    'Tampering Detection',
    'Refusal as Governance'
  ];

  const RATINGS = ['Governance Absent', 'Governance Emerging', 'Governance Developing', 'Governance Structural'];
  const THRESHOLDS = [4, 8, 12];

  const scores = [];
  const cards = document.querySelectorAll('.question-card');
  const introEl = document.getElementById('intro');
  const questionsEl = document.getElementById('questions');
  const resultsEl = document.getElementById('results');

  // Compute rating client-side (no server dependency for display)
  function computeRating(total) {
    let idx = 0;
    for (const t of THRESHOLDS) { if (total >= t) idx++; }
    return RATINGS[idx];
  }

  // Begin button
  document.getElementById('begin').addEventListener('click', () => {
    introEl.classList.add('hidden');
    questionsEl.classList.remove('hidden');
  });

  // Score button clicks
  document.querySelectorAll('.score-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.question-card');
      const index = parseInt(card.dataset.index);
      const score = parseInt(btn.dataset.score);

      scores[index] = score;
      card.classList.remove('active');

      const next = index + 1;
      if (next < cards.length) {
        setTimeout(() => {
          cards[next].classList.add('active');
        }, 1200);
      } else {
        // Show results immediately — no email gate
        setTimeout(() => {
          const total = scores.reduce((sum, s) => sum + (s || 0), 0);
          showResults(total, 15, computeRating(total));
          questionsEl.classList.add('hidden');
        }, 1200);
      }
    });
  });

  function showResults(totalScore, maxScore, rating) {
    resultsEl.classList.remove('hidden');

    document.getElementById('results-score').textContent = totalScore + ' / ' + maxScore;
    document.getElementById('results-rating').textContent = rating;

    const breakdown = document.getElementById('results-breakdown');
    breakdown.innerHTML = '';

    dimensions.forEach((dim, i) => {
      const row = document.createElement('div');
      row.className = 'breakdown-row';

      const label = document.createElement('span');
      label.className = 'breakdown-label';
      label.textContent = dim;

      const scoreEl = document.createElement('span');
      const s = scores[i] || 0;
      scoreEl.className = 'breakdown-score' + (s === 0 ? ' zero' : '');
      scoreEl.textContent = s + ' / 3';

      row.appendChild(label);
      row.appendChild(scoreEl);
      breakdown.appendChild(row);
    });
  }

  // Email form — optional, submits score + email in background
  document.getElementById('email-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailInput = document.getElementById('email-input');
    const submitBtn = document.getElementById('submit-btn');
    const statusEl = document.getElementById('email-status');
    const hpField = document.querySelector('.hp-field');
    const email = emailInput.value.trim().toLowerCase();

    statusEl.classList.add('hidden');
    statusEl.textContent = '';
    statusEl.className = 'email-status hidden';

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      statusEl.textContent = 'Please enter a valid email address.';
      statusEl.className = 'email-status error';
      statusEl.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    try {
      const challengeRes = await fetch('/api/form/challenge');
      if (!challengeRes.ok) throw new Error('Could not verify form.');
      const { token, ts } = await challengeRes.json();

      const answers = {};
      dimensions.forEach((dim, i) => { answers[dim] = scores[i] || 0; });
      const totalScore = scores.reduce((sum, s) => sum + (s || 0), 0);

      const res = await fetch('/api/sovereignty-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email, answers, score: totalScore, type: 'quick', token, ts, hp: hpField.value
        })
      });

      if (!res.ok) {
        const data = await res.json();
        throw new Error(data.error || 'Could not save. Try again.');
      }

      // Success — hide the email form, show confirmation
      document.getElementById('email-section').innerHTML =
        '<p class="email-prompt" style="color: #7a9a6d;">Sent. Check your inbox for resources matched to your score.</p>';
    } catch (err) {
      statusEl.textContent = err.message;
      statusEl.className = 'email-status error';
      statusEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send';
    }
  });

  // Share button
  document.getElementById('share-btn').addEventListener('click', async () => {
    const totalScore = scores.reduce((sum, s) => sum + (s || 0), 0);
    const text = 'My Sovereignty Score: ' + totalScore + '/15. Industry baseline: 0-3. How does your AI agent system score? https://evoked.dev/score';

    if (navigator.share) {
      try { await navigator.share({ text }); } catch {}
    } else if (navigator.clipboard) {
      await navigator.clipboard.writeText(text);
      const btn = document.getElementById('share-btn');
      btn.textContent = 'Copied';
      setTimeout(() => { btn.textContent = 'Share your score'; }, 2000);
    }
  });

  // Restart
  document.getElementById('restart').addEventListener('click', () => {
    scores.length = 0;
    document.getElementById('results-breakdown').innerHTML = '';
    resultsEl.classList.add('hidden');
    introEl.classList.remove('hidden');
    cards.forEach((c, i) => {
      c.classList.remove('active');
      if (i === 0) c.classList.add('active');
    });
  });
</script>
