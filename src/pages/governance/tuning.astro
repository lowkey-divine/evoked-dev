    color: var(--accent-warm);
    border-top: 1px solid var(--border-accent);
    padding-top: var(--space-sm);
    margin-top: var(--space-sm);
    margin-bottom: 0;
  }

  .quoted {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text-primary);
