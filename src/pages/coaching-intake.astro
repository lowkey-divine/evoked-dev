---
import ElevationLayout from '../layouts/ElevationLayout.astro';
import Hero from '../components/elevation/Hero.astro';
import Section from '../components/elevation/Section.astro';

export const prerender = false;
---

<ElevationLayout
  title="Start a conversation"
  description="Three questions. No pressure. Just a way for us to understand where you are before we talk."
>
  <Hero
    eyebrowParts={["Engage", "Coaching"]}
    headline="Start a conversation."
    metaphor={["Three questions. No pressure."]}
    sub="Just a way for us to understand where you are."
  />

  <section class="intake-section">
    <form id="coaching-form" class="intake-form" novalidate>

      <div class="step active" data-step="1">
        <label for="co-where">Where are you right now?</label>
        <p class="step-subtext">Not your job title. Where you are with AI, with your team, with the change you're navigating.</p>
        <textarea id="co-where" name="where" rows="5" required placeholder=""></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="2">
        <label for="co-shifting">What's shifting?</label>
        <p class="step-subtext">What prompted you to look for support? What feels unsteady?</p>
        <textarea id="co-shifting" name="shifting" rows="5" placeholder=""></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="3">
        <label for="co-support">What kind of support are you looking for?</label>
        <p class="step-subtext">There's no wrong answer. Some people want a thought partner. Some want someone to hold the mirror. Some don't know yet.</p>
        <textarea id="co-support" name="support" rows="5" placeholder=""></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="4">
        <label for="co-name">Your name</label>
        <input type="text" id="co-name" name="name" required />
        <label for="co-email" class="mt-md">Your email</label>
        <input type="email" id="co-email" name="email" required />
        <button type="submit" class="step-submit mt-md">Send it over</button>
        <p id="co-status" class="form-status" aria-live="polite"></p>
      </div>

      <div class="step-progress" aria-hidden="true">
        <span class="progress-dot active" data-for="1"></span>
        <span class="progress-dot" data-for="2"></span>
        <span class="progress-dot" data-for="3"></span>
        <span class="progress-dot" data-for="4"></span>
      </div>

      <button type="button" class="step-back" id="step-back" style="display:none;">Back</button>
    </form>
  </section>

  <Section marker="NOTA · BENE" heading="What happens next" closing={true}>
    <p class="lede">
      I read every message personally. If there's a fit, I'll reach out within a
      few days. No pitch. Just a conversation about what you need.
    </p>
  </Section>
</ElevationLayout>

<script>
  function attachCoachingIntake() {
    const form = document.getElementById('coaching-form') as HTMLFormElement | null;
    if (!form || form.dataset.wired === 'true') return;
    form.dataset.wired = 'true';

    const status = document.getElementById('co-status') as HTMLParagraphElement;
    const steps = form.querySelectorAll('.step') as NodeListOf<HTMLElement>;
    const dots = form.querySelectorAll('.progress-dot') as NodeListOf<HTMLElement>;
    const backBtn = document.getElementById('step-back') as HTMLButtonElement;
    let current = 1;
    const formLoadedAt = Date.now();

    function showStep(n: number) {
      steps.forEach(s => s.classList.remove('active'));
      dots.forEach(d => d.classList.remove('active'));
      const step = form!.querySelector(`[data-step="${n}"]`) as HTMLElement;
      const dot = form!.querySelector(`.progress-dot[data-for="${n}"]`) as HTMLElement;
      if (step) step.classList.add('active');
      if (dot) dot.classList.add('active');

      dots.forEach(d => {
        const forStep = parseInt(d.getAttribute('data-for') || '0');
        if (forStep < n) d.classList.add('completed');
        else d.classList.remove('completed');
      });

      backBtn.style.display = n > 1 ? 'block' : 'none';
      current = n;

      const firstInput = step?.querySelector('input, textarea') as HTMLElement;
      if (firstInput) setTimeout(() => firstInput.focus(), 100);
    }

    form.querySelectorAll('.step-next').forEach(btn => {
      btn.addEventListener('click', () => {
        const step = (btn as HTMLElement).closest('.step') as HTMLElement;
        const required = step.querySelectorAll('[required]') as NodeListOf<HTMLInputElement | HTMLTextAreaElement>;
        let valid = true;
        required.forEach(input => { if (!input.value.trim()) valid = false; });
        if (valid) {
          const stepNum = parseInt(step.getAttribute('data-step') || '1');
          showStep(stepNum + 1);
        }
      });
    });

    backBtn.addEventListener('click', () => { if (current > 1) showStep(current - 1); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';

      const name = (document.getElementById('co-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('co-email') as HTMLInputElement).value.trim();
      const where = (document.getElementById('co-where') as HTMLTextAreaElement).value.trim();
      const shifting = (document.getElementById('co-shifting') as HTMLTextAreaElement).value.trim();
      const support = (document.getElementById('co-support') as HTMLTextAreaElement).value.trim();

      if (!name || !email) return;

      const button = form!.querySelector('[type="submit"]') as HTMLButtonElement;
      button.disabled = true;
      button.textContent = 'Sending...';

      try {
        const c = await fetch('/api/form/challenge');
        if (!c.ok) throw new Error('failed');
        const { token, ts } = await c.json();

        const res = await fetch('/api/coaching-intake', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, where, shifting, support, token, ts, hp: '', formLoadedAt }),
        });

        if (res.ok) {
          status.textContent = 'Received. I will be in touch.';
          status.className = 'form-status success';
          form!.reset();
          steps.forEach(s => s.classList.remove('active'));
          dots.forEach(d => { d.classList.add('completed'); d.classList.remove('active'); });
          backBtn.style.display = 'none';
        } else {
          const resData = await res.json();
          status.textContent = resData.error || 'Something went wrong. Try again.';
          status.className = 'form-status error';
        }
      } catch {
        status.textContent = 'Something went wrong. Try again.';
        status.className = 'form-status error';
      } finally {
        button.disabled = false;
        button.textContent = 'Send it over';
      }
    });
  }
  attachCoachingIntake();
  document.addEventListener('astro:after-swap', attachCoachingIntake);
</script>

<style>
  /* /coaching-intake - founder-public register, three open-question
     form in J chrome. Same form pattern as /build-with-us (and
     /consulting-intake) - brass focus rings, brass progress dots,
     brass-outlined continue button. No step-labels here: the
     coaching register is gentler than the build-with-us anatomy
     labels. Step-subtext carries the soft framing instead. */

  .intake-section {
    padding: clamp(2rem, 1.5rem + 2vw, 4rem) 0
            clamp(3rem, 2rem + 3vw, 5rem);
    border-top: 1px solid var(--el-rule);
  }
  .intake-form {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
  }
  .step { display: none; }
  .step.active {
    display: block;
    animation: intake-fade-in 0.32s ease;
  }
  @keyframes intake-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .step label:first-child {
    display: block;
    font-family: var(--el-display);
    font-size: clamp(1.1rem, 1rem + 0.4vw, 1.35rem);
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: 0.005em;
    color: var(--el-text);
    margin-bottom: 0.5rem;
  }
  .step-subtext {
    font-family: var(--el-body);
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1rem);
    line-height: 1.6;
    color: var(--el-text-soft);
    margin: 0 0 clamp(1rem, 0.75rem + 0.75vw, 1.5rem);
    max-width: 60ch;
  }

  .step input[type="text"],
  .step input[type="email"],
  .step textarea {
    width: 100%;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--el-rule);
    background: transparent;
    color: var(--el-text);
    font-family: var(--el-body);
    font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
    line-height: 1.6;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .step input:focus,
  .step textarea:focus {
    outline: none;
    border-color: var(--el-accent);
    box-shadow: 0 0 0 1px var(--el-accent);
  }
  .step input::placeholder,
  .step textarea::placeholder { color: var(--el-text-quiet); }
  .step textarea { resize: vertical; }

  /* Multi-input contact step gets ui-label treatment on its
     subsequent labels (name + email) for visual balance. */
  .step label:not(:first-child) {
    display: block;
    font-family: var(--el-ui);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
    margin-bottom: 0.4rem;
  }

  .step-next,
  .step-submit {
    margin-top: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    padding: 0.6rem 1.6rem;
    background: transparent;
    color: var(--el-accent);
    border: 1px solid var(--el-accent);
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .step-next:hover,
  .step-submit:hover {
    background: var(--el-accent);
    color: var(--el-bg);
  }
  .step-submit:disabled { opacity: 0.55; cursor: wait; }

  .mt-md { margin-top: clamp(0.85rem, 0.7rem + 0.4vw, 1.2rem); }

  .step-progress {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-top: clamp(2rem, 1.5rem + 1.5vw, 3rem);
  }
  .progress-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--el-rule);
    transition: background 0.2s ease, opacity 0.2s ease;
  }
  .progress-dot.active { background: var(--el-accent); }
  .progress-dot.completed { background: var(--el-accent); opacity: 0.4; }

  .step-back {
    display: block;
    margin: 0.85rem auto 0;
    background: none;
    border: none;
    color: var(--el-text-quiet);
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0.5rem 1rem;
  }
  .step-back:hover { color: var(--el-text-soft); }

  .form-status {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 1rem;
    min-height: 1.2em;
    color: var(--el-text-quiet);
  }
  .form-status.success { color: var(--el-accent); }
  .form-status.error   { color: #c44; }
</style>
