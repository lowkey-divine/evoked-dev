---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReflectionInvitation from '../../components/ReflectionInvitation.astro';
import { getProductBySlug } from '../../lib/products/registry';

const product = getProductBySlug('identity-violation-assessment')!;
---

<BaseLayout title="Thank You" description="Your Identity Violation Assessment Kit is ready to download.">
  <div class="hero">
    <h1>Thank you.</h1>
    <p class="tagline">Your Identity Violation Assessment is ready.</p>
  </div>

  <section class="container thank-you-content">
    <div class="download-card">
      <h2>Download Your Assessment</h2>
      <p>Eight domains evaluating whether your agent system can tell the difference between a genuine entity and a compromised one. The four-category Identity Violation Taxonomy maps harms, not attacks.</p>
      <p>Start with Domain 1: Self-Description Integrity. Everything builds from there.</p>
      <a href="/downloads/Identity-Violation-Assessment-Kit-v1.0.pdf" class="btn btn-primary mt-md" download>Download PDF</a>
      <p class="text-muted mt-md" style="font-size: 0.85rem;">If you have any issues with your download, reach out at <a href="mailto:evokesupports@icloud.com">evokesupports@icloud.com</a>.</p>
    </div>
  </section>

  <section class="container">
    <h2>What's Next</h2>
    <div class="next-steps">
      <div class="card">
        <h3>Assess Your System</h3>
        <p>Score the eight domains against what your architecture enforces today. The industry baseline is 0-4 out of 24.</p>
      </div>
      <div class="card">
        <h3>Complete the Audit</h3>
        <p>Pair with the <a href="/products/ostrom-score">Ostrom Score</a> for commons health and the <a href="/products/agent-consent-architecture">Agent Consent Architecture</a> for participation.</p>
      </div>
      <div class="card">
        <h3>Go Deeper</h3>
        <p>If identity integrity gaps are structural, a <a href="/governance-audit">Governance Audit</a> can map the remediation path.</p>
      </div>
      <div class="card">
        <h3>Talk It Through</h3>
        <p>Book a free <a href="https://cal.com/cal.com-evoked/discovery-call" target="_blank" rel="noopener">discovery call</a> to discuss your findings.</p>
      </div>
    </div>
  </section>

  <ReflectionInvitation prompt={product.reciprocityPrompt} productName={product.name} />
</BaseLayout>

<style>
  .thank-you-content { max-width: 640px; margin-left: auto; margin-right: auto; }
  .download-card { background: var(--accent-subtle); border: 2px solid var(--accent-warm); border-radius: 12px; padding: var(--space-lg); text-align: center; }
  .download-card h2 { margin-top: 0; }
  .next-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-md); }
  .next-steps .card h3 { font-size: 1.1rem; }
  .next-steps .card p { font-size: 0.9rem; margin-bottom: 0; }
  .btn-primary { background: var(--accent-warm); color: var(--bg-deep); display: inline-block; }
  .btn-primary:hover { background: var(--accent-glow); color: var(--bg-deep); }
</style>
