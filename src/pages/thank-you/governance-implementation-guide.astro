---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReflectionInvitation from '../../components/ReflectionInvitation.astro';
import { getProductBySlug } from '../../lib/products/registry';

const product = getProductBySlug('governance-implementation-guide')!;
---

<BaseLayout title="Thank You" description="Your Agent Governance Implementation Guide is ready to download.">
  <div class="hero">
    <h1>Thank you.</h1>
    <p class="tagline">Your implementation guide is ready.</p>
  </div>

  <section class="container thank-you-content">
    <div class="download-card">
      <h2>Download Your Guide</h2>
      <p>25 pages of framework-specific governance implementation. CrewAI, LangGraph, and Pydantic AI sections with code examples, the five-property sequence, refusal categories, and EU AI Act mapping.</p>
      <p>Start by running the governance scan on your project (Chapter 1).</p>
      <a href="/downloads/Agent-Governance-Implementation-Guide-v1.0.pdf" class="btn btn-primary mt-md" download>Download PDF</a>
      <p class="text-muted mt-md" style="font-size: 0.85rem;">If you have any issues with your download, reach out at <a href="mailto:evokesupports@icloud.com">evokesupports@icloud.com</a>.</p>
    </div>
  </section>

  <section class="container">
    <h2>What's Next</h2>
    <div class="next-steps">
      <div class="card">
        <h3>Implement and Verify</h3>
        <p>Follow the guide, then re-assess your five governance properties. Watch your score go from where it was to 5/5.</p>
      </div>
      <div class="card">
        <h3>Complete Trust Architecture</h3>
        <p>The <a href="/products/trust-architecture-complete">Trust Architecture Complete bundle ($149)</a> adds identity, voice, and restraint on top of governance.</p>
      </div>
      <div class="card">
        <h3>Get a Governance Audit</h3>
        <p>We audit your agent system hands-on, in your codebase, with your team. <a href="/consulting">Starting at $3,000</a>.</p>
      </div>
      <div class="card">
        <h3>Talk It Through</h3>
        <p>Book a free <a href="https://cal.com/cal.com-evoked/discovery-call" target="_blank" rel="noopener">discovery call</a> to discuss your implementation.</p>
      </div>
    </div>
  </section>

  <ReflectionInvitation prompt={product.reciprocityPrompt} productName={product.name} />
</BaseLayout>

<style>
  .thank-you-content { max-width: 640px; margin-left: auto; margin-right: auto; }
  .download-card { background: var(--accent-subtle); border: 2px solid var(--accent-warm); border-radius: 12px; padding: var(--space-lg); text-align: center; }
  .download-card h2 { margin-top: 0; }
  .download-card code { background: var(--bg-surface); padding: 2px 6px; border-radius: 4px; font-size: 0.85rem; }
  .next-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-md); }
  .next-steps .card h3 { font-size: 1.1rem; }
  .next-steps .card p { font-size: 0.9rem; margin-bottom: 0; }
  .btn-primary { background: var(--accent-warm); color: var(--bg-deep); display: inline-block; }
  .btn-primary:hover { background: var(--accent-glow); color: var(--bg-deep); }
</style>
