---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReflectionInvitation from '../../components/ReflectionInvitation.astro';
import { getProductBySlug } from '../../lib/products/registry';

const product = getProductBySlug('ostrom-score')!;
---

<BaseLayout title="Thank You" description="Your Ostrom Score Self-Assessment Kit is ready to download.">
  <div class="hero">
    <h1>Thank you.</h1>
    <p class="tagline">Your Ostrom Score is ready.</p>
  </div>

  <section class="container thank-you-content">
    <div class="download-card">
      <h2>Download Your Assessment</h2>
      <p>Eight principles from Nobel Prize-winning commons governance research. 32 diagnostic questions. Score your agent system against the structural conditions that cooperation requires.</p>
      <p>Most organizations score between 0 and 4 out of 24. The value is in the honesty, not the number.</p>
      <a href="/downloads/Ostrom-Score-Self-Assessment-Kit-v1.0.pdf" class="btn btn-primary mt-md" download>Download PDF</a>
      <p class="text-muted mt-md" style="font-size: 0.85rem;">If you have any issues with your download, reach out at <a href="mailto:evokesupports@icloud.com">evokesupports@icloud.com</a>.</p>
    </div>
  </section>

  <section class="container">
    <h2>What's Next</h2>
    <div class="next-steps">
      <div class="card">
        <h3>Score Honestly</h3>
        <p>Score what exists in your architecture today. Not your roadmap. Not your intentions.</p>
      </div>
      <div class="card">
        <h3>Complete the Audit</h3>
        <p>The <a href="/products/identity-violation-assessment">Identity Violation Assessment</a> and <a href="/products/agent-consent-architecture">Agent Consent Architecture</a> complete the Level 6 Governance Audit.</p>
      </div>
      <div class="card">
        <h3>Go Deeper</h3>
        <p>If your score surfaces structural gaps, a <a href="/governance-audit">Governance Diagnostic</a> can help close them.</p>
      </div>
      <div class="card">
        <h3>Talk It Through</h3>
        <p>Book a free <a href="https://cal.com/cal.com-evoked/discovery-call" target="_blank" rel="noopener">discovery call</a> to discuss your results.</p>
      </div>
    </div>
  </section>

  <ReflectionInvitation prompt={product.reciprocityPrompt} productName={product.name} />
</BaseLayout>

<style>
  .thank-you-content { max-width: 640px; margin-left: auto; margin-right: auto; }
  .download-card { background: var(--accent-subtle); border: 2px solid var(--accent-warm); border-radius: 12px; padding: var(--space-lg); text-align: center; }
  .download-card h2 { margin-top: 0; }
  .next-steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-md); }
  .next-steps .card h3 { font-size: 1.1rem; }
  .next-steps .card p { font-size: 0.9rem; margin-bottom: 0; }
  .btn-primary { background: var(--accent-warm); color: var(--bg-deep); display: inline-block; }
  .btn-primary:hover { background: var(--accent-glow); color: var(--bg-deep); }
</style>
