---
import ElevationLayout from '../layouts/ElevationLayout.astro';
import Hero from '../components/elevation/Hero.astro';
import Section from '../components/elevation/Section.astro';
import FitAssessment from '../components/ai/FitAssessment.astro';
import { webApplicationJsonLd } from '../lib/structured-data';

export const prerender = false;

const fitJsonLd = webApplicationJsonLd(
  "AI Governance Fit Assessment",
  "AI-powered assessment that evaluates whether your project aligns with sovereignty-honoring governance consulting. Honest read, no commitment, no data stored.",
  "https://evoked.dev/fit"
);
---

<ElevationLayout
  title="Fit Assessment"
  description="See if your project is a good fit for my consulting services."
  structuredData={fitJsonLd}
>
  <Hero
    eyebrowParts={["Engage", "Fit assessment"]}
    headline="Is this a good fit?"
    metaphor={["Honest assessment of project alignment."]}
  />

  <section class="fit-disclosure">
    <p>
      This assessment uses Claude AI by
      <a href="https://www.anthropic.com" target="_blank" rel="noopener">Anthropic</a>
      to evaluate project fit. Your description is sent to their API. Nothing is stored.
    </p>
  </section>

  <section class="fit-assessment-wrap">
    <FitAssessment />
  </section>

  <Section marker="FIG · I" heading="What I look for">
    <div class="fit-grid">
      <div class="fit-column fit-strong">
        <h3>Strong fit</h3>
        <ul>
          <li>Teams deploying AI agents who need context, intent, or specification engineering</li>
          <li>Organizations scaling agents and struggling with governance or verification</li>
          <li>Family-focused apps needing child safety and COPPA compliance</li>
          <li>Products handling sensitive personal data</li>
          <li>Companies wanting sovereignty-honoring design</li>
        </ul>
      </div>
      <div class="fit-column fit-moderate">
        <h3>Moderate fit</h3>
        <ul>
          <li>Teams strong at prompt craft but unsure what comes next</li>
          <li>General privacy reviews for consumer apps</li>
          <li>Security audits and code review</li>
        </ul>
      </div>
      <div class="fit-column fit-limited">
        <h3>Limited fit</h3>
        <ul>
          <li>Growth hacking or engagement optimization</li>
          <li>Surveillance or tracking systems</li>
          <li>Products extracting value from users</li>
          <li>Quick fixes without architectural thinking</li>
        </ul>
      </div>
    </div>
  </Section>

  <Section marker="NOTA · BENE" heading="Not sure?" closing={true}>
    <p class="lede">
      <a class="fit-inline-link" href="/ask">Ask me directly</a>
      or
      <a class="fit-inline-link" href="mailto:erin@evoked.dev?subject=Consulting Inquiry">reach out</a>.
    </p>
  </Section>
</ElevationLayout>

<style>
  /* /fit - J register chrome for the assessment surface.
     Founder-public register. The FitAssessment component keeps
     its own internal styling; this stylesheet only handles the
     outer chrome (disclosure, wrap, fit-grid columns, inline
     links in the close). */

  .fit-disclosure {
    max-width: var(--el-content-max);
    margin: 0 auto;
    padding: 0 var(--el-content-pad) clamp(1rem, 0.75rem + 1vw, 1.5rem);
  }
  .fit-disclosure p {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--el-text-quiet);
    line-height: 1.6;
    max-width: 70ch;
    margin: 0;
  }
  .fit-disclosure a {
    color: var(--el-text-soft);
    text-decoration: underline;
  }
  .fit-disclosure a:hover { color: var(--el-accent); }

  .fit-assessment-wrap {
    max-width: var(--el-content-max);
    margin: 0 auto;
    padding: 0 var(--el-content-pad) clamp(2rem, 1.5rem + 2vw, 3.5rem);
  }

  /* ---- FIG I: three-column fit grid ---- */
  .fit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: clamp(1rem, 0.75rem + 1vw, 1.75rem);
    margin-top: clamp(1.25rem, 1rem + 1vw, 2rem);
  }
  .fit-column {
    padding: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    border: 1px solid var(--el-rule);
  }
  .fit-column h3 {
    font-family: var(--el-display);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  /* Semantic signal preserved (strong / moderate / limited) but
     toned to harmonize with the parchment palette. */
  .fit-column.fit-strong   h3 { color: #5a8a4a; }
  .fit-column.fit-moderate h3 { color: var(--el-accent); }
  .fit-column.fit-limited  h3 { color: #b89a3a; }

  .fit-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .fit-column li {
    padding: 0.75rem 0;
    font-family: var(--el-body);
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1rem);
    line-height: 1.5;
    color: var(--el-text-soft);
    border-bottom: 1px solid var(--el-rule);
  }
  .fit-column li:last-child { border-bottom: none; }

  /* ---- NOTA BENE close: inline routing links ---- */
  .fit-inline-link {
    color: var(--el-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--el-accent);
  }
  .fit-inline-link:hover {
    color: var(--el-text);
    border-color: var(--el-text);
  }
</style>
