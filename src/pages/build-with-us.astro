---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="Build With Us" description="Tell us about the app you want to build. Sovereignty-honoring software starts with a conversation.">
  <div class="hero-small">
    <h1>Tell us what you want to build.</h1>
    <p class="tagline">Every app we build honors the people who use it. If that matters to you, we should talk.</p>
  </div>

  <section class="container">
    <div class="coming-soon">
      <p class="coming-soon-label">Coming soon</p>
      <p>Our intake form is being rebuilt. In the meantime, reach out directly at <a href="mailto:evokesupports@icloud.com">evokesupports@icloud.com</a> and tell us what you want to build.</p>
    </div>
  </section>

  <section class="container">
    <div class="already-built">
      <h2>What we've built</h2>
      <p>These are live projects - sovereignty-honoring software built the way we believe it should be.</p>
      <a href="/projects" class="btn">See our projects</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-small {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .hero-small h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-xs);
  }

  .hero-small .tagline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .coming-soon {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .coming-soon-label {
    font-family: var(--font-display);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-warm);
    margin-bottom: var(--space-sm);
  }

  .coming-soon p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .coming-soon a {
    color: var(--accent-warm);
    text-decoration: underline;
  }

  .coming-soon a:hover {
    color: var(--accent-glow);
  }

  .already-built {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .already-built h2 {
    font-size: 1.3rem;
    margin-bottom: var(--space-sm);
  }

  .already-built p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }
</style>
