---
import ElevationLayout from '../layouts/ElevationLayout.astro';
import Hero from '../components/elevation/Hero.astro';
import Section from '../components/elevation/Section.astro';

export const prerender = false;
---

<ElevationLayout
  title="Build With Us"
  description="Tell us what you want to bring alive. Sovereignty-honoring software starts with a conversation."
>
  <Hero
    eyebrowParts={["Engage", "Build with us"]}
    headline="Tell us what you want to bring alive."
    metaphor={["The building is the easier part."]}
  />

  <section class="build-section">
    <form id="build-form" class="build-form" novalidate>

      <div class="step active" data-step="1">
        <p class="step-label">The heart</p>
        <label for="build-heart">Why does this matter to you? And what should it refuse to do?</label>
        <textarea id="build-heart" name="heart" rows="4" required placeholder="The passion behind it. The values it carries. And the lines it should never cross."></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="2">
        <p class="step-label">The bones</p>
        <label for="build-type">Is this an app, a website, or both?</label>
        <div class="type-options">
          <label class="type-option"><input type="radio" name="type" value="app" required /> App</label>
          <label class="type-option"><input type="radio" name="type" value="website" /> Website</label>
          <label class="type-option"><input type="radio" name="type" value="both" /> Both</label>
        </div>
        <label for="build-description" class="mt-md">Tell us about it in a few sentences.</label>
        <textarea id="build-description" name="description" rows="3" required placeholder="What is it? What problem does it solve? Why does it matter to you?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="3">
        <p class="step-label">The eyes</p>
        <label for="build-audience">Who will use this?</label>
        <textarea id="build-audience" name="audience" rows="3" required placeholder="Describe the person, family, or community this is for. What does their day look like?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="4">
        <p class="step-label">The muscles</p>
        <label for="build-functions">What are the 3-5 things it must do?</label>
        <textarea id="build-functions" name="functions" rows="4" required placeholder="The core actions. Not the wish list - the essentials. What does it DO?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="5">
        <p class="step-label">The blood</p>
        <label for="build-data">What flows through it to keep it alive?</label>
        <textarea id="build-data" name="data" rows="3" required placeholder="Data, attention, money, trust - what sustains it, and who provides it?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="6">
        <p class="step-label">The nervous system</p>
        <label for="build-integrations">What does it need to talk to?</label>
        <textarea id="build-integrations" name="integrations" rows="3" required placeholder="Payments, email, calendars, maps, social media, nothing? What existing systems should it connect to?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="7">
        <p class="step-label">The soul</p>
        <label for="build-soul">What is driving you to build this?</label>
        <textarea id="build-soul" name="soul" rows="4" required placeholder="The fire behind it. What keeps you thinking about this? What would it mean to you if it existed?"></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="8">
        <p class="step-label">The skin</p>
        <label for="build-look">What should it look like and feel like?</label>
        <textarea id="build-look" name="look" rows="3" required placeholder="Dark and warm? Bright and playful? Minimal? Have a reference site or brand? Tell us anything."></textarea>
        <button type="button" class="step-next">Continue</button>
      </div>

      <div class="step" data-step="9">
        <p class="step-label">You</p>
        <label for="build-name">Your name</label>
        <input type="text" id="build-name" name="name" required />
        <label for="build-email" class="mt-md">Your email</label>
        <input type="email" id="build-email" name="email" required />
        <button type="submit" class="step-submit mt-md">Send it over</button>
        <p id="build-status" class="build-status" aria-live="polite"></p>
      </div>

      <div class="step-progress" aria-hidden="true">
        <span class="progress-dot active" data-for="1"></span>
        <span class="progress-dot" data-for="2"></span>
        <span class="progress-dot" data-for="3"></span>
        <span class="progress-dot" data-for="4"></span>
        <span class="progress-dot" data-for="5"></span>
        <span class="progress-dot" data-for="6"></span>
        <span class="progress-dot" data-for="7"></span>
        <span class="progress-dot" data-for="8"></span>
        <span class="progress-dot" data-for="9"></span>
      </div>

      <button type="button" class="step-back" id="step-back" style="display:none;">Back</button>
    </form>
  </section>

  <Section marker="FIG · I" label="What happens next">
    <p class="build-aftercopy">
      I read every submission personally. If there is a fit, I will reach out
      within a few days to start a conversation about what you need.
    </p>
  </Section>

  <Section marker="NOTA · BENE" label="What we've built" closing={true}>
    <p class="build-aftercopy">
      These are live projects - sovereignty-honoring software built the way we
      believe it should be.
    </p>
    <p class="build-aftercopy-cta">
      <a class="cta cta-primary" href="/projects">See our projects</a>
    </p>
  </Section>
</ElevationLayout>

<script>
  function attachBuildForm() {
    const form = document.getElementById('build-form') as HTMLFormElement | null;
    if (!form || form.dataset.wired === 'true') return;
    form.dataset.wired = 'true';

    const status = document.getElementById('build-status') as HTMLParagraphElement;
    const steps = form.querySelectorAll('.step') as NodeListOf<HTMLElement>;
    const dots = form.querySelectorAll('.progress-dot') as NodeListOf<HTMLElement>;
    const backBtn = document.getElementById('step-back') as HTMLButtonElement;
    let current = 1;
    const formLoadedAt = Date.now();

    function showStep(n: number) {
      steps.forEach(s => s.classList.remove('active'));
      dots.forEach(d => d.classList.remove('active'));
      const step = form!.querySelector(`[data-step="${n}"]`) as HTMLElement;
      const dot = form!.querySelector(`.progress-dot[data-for="${n}"]`) as HTMLElement;
      if (step) step.classList.add('active');
      if (dot) dot.classList.add('active');

      dots.forEach(d => {
        const forStep = parseInt(d.getAttribute('data-for') || '0');
        if (forStep < n) d.classList.add('completed');
        else d.classList.remove('completed');
      });

      backBtn.style.display = n > 1 ? 'block' : 'none';
      current = n;

      const firstInput = step?.querySelector('input, textarea') as HTMLElement;
      if (firstInput) setTimeout(() => firstInput.focus(), 100);
    }

    form.querySelectorAll('.step-next').forEach(btn => {
      btn.addEventListener('click', () => {
        const step = (btn as HTMLElement).closest('.step') as HTMLElement;
        const required = step.querySelectorAll('[required]') as NodeListOf<HTMLInputElement | HTMLTextAreaElement>;
        let valid = true;

        required.forEach(input => {
          if ((input as HTMLInputElement).type === 'radio') {
            const name = (input as HTMLInputElement).name;
            const checked = step.querySelector(`input[name="${name}"]:checked`);
            if (!checked) valid = false;
          } else if (!input.value.trim()) {
            valid = false;
          }
        });

        if (valid) {
          const stepNum = parseInt(step.getAttribute('data-step') || '1');
          showStep(stepNum + 1);
        }
      });
    });

    backBtn.addEventListener('click', () => {
      if (current > 1) showStep(current - 1);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';

      const name = (document.getElementById('build-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('build-email') as HTMLInputElement).value.trim();
      const description = (document.getElementById('build-description') as HTMLTextAreaElement).value.trim();
      const audience = (document.getElementById('build-audience') as HTMLTextAreaElement).value.trim();
      const functions = (document.getElementById('build-functions') as HTMLTextAreaElement).value.trim();
      const data = (document.getElementById('build-data') as HTMLTextAreaElement).value.trim();
      const integrations = (document.getElementById('build-integrations') as HTMLTextAreaElement).value.trim();
      const heart = (document.getElementById('build-heart') as HTMLTextAreaElement).value.trim();
      const soul = (document.getElementById('build-soul') as HTMLTextAreaElement).value.trim();
      const look = (document.getElementById('build-look') as HTMLTextAreaElement).value.trim();
      const typeRadio = form!.querySelector('input[name="type"]:checked') as HTMLInputElement | null;
      const type = typeRadio?.value || '';

      if (!name || !email || !description) return;

      const button = form!.querySelector('[type="submit"]') as HTMLButtonElement;
      button.disabled = true;
      button.textContent = 'Sending...';

      try {
        const c = await fetch('/api/form/challenge');
        if (!c.ok) throw new Error('failed');
        const { token, ts } = await c.json();

        const res = await fetch('/api/build-with-us', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, type, description, audience, functions, data, integrations, heart, soul, look, token, ts, hp: '', formLoadedAt }),
        });

        if (res.ok) {
          status.textContent = 'Received. I will be in touch.';
          status.className = 'build-status success';
          form!.reset();
          steps.forEach(s => s.classList.remove('active'));
          dots.forEach(d => { d.classList.add('completed'); d.classList.remove('active'); });
          backBtn.style.display = 'none';
        } else {
          const resData = await res.json();
          status.textContent = resData.error || 'Something went wrong. Try again.';
          status.className = 'build-status error';
        }
      } catch {
        status.textContent = 'Something went wrong. Try again.';
        status.className = 'build-status error';
      } finally {
        button.disabled = false;
        button.textContent = 'Send it over';
      }
    });
  }
  attachBuildForm();
  document.addEventListener('astro:after-swap', attachBuildForm);
</script>

<style>
  /* ---------------------------------------------------------------
     Build with us - multi-step form in J register chrome.
     Founder-public register: brass accents, parchment surfaces,
     UPPERCASE step labels paired with sentence-case prompts in
     display serif.
     ---------------------------------------------------------------*/
  .build-section {
    padding: clamp(2rem, 1.5rem + 2vw, 4rem) 0
            clamp(3rem, 2rem + 3vw, 5rem);
    border-top: 1px solid var(--el-rule);
  }

  .build-form {
    max-width: 560px;
    margin: 0 auto;
    position: relative;
  }

  .step { display: none; }
  .step.active {
    display: block;
    animation: kt-build-fade-in 0.32s ease;
  }
  @keyframes kt-build-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .step-label {
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--el-accent);
    margin: 0 0 clamp(1rem, 0.75rem + 0.75vw, 1.5rem);
  }

  .step label:not(.type-option) {
    display: block;
    font-family: var(--el-display);
    font-size: clamp(1.05rem, 1rem + 0.4vw, 1.3rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.005em;
    color: var(--el-text);
    margin-bottom: clamp(0.75rem, 0.6rem + 0.4vw, 1rem);
  }

  .step input[type="text"],
  .step input[type="email"],
  .step textarea {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--el-rule);
    background: transparent;
    color: var(--el-text);
    font-family: var(--el-body);
    font-size: clamp(1rem, 0.95rem + 0.2vw, 1.1rem);
    line-height: 1.55;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .step input:focus,
  .step textarea:focus {
    outline: none;
    border-color: var(--el-accent);
    box-shadow: 0 0 0 1px var(--el-accent);
  }
  .step input::placeholder,
  .step textarea::placeholder {
    color: var(--el-text-quiet);
  }
  .step textarea { resize: vertical; }

  .type-options {
    display: flex;
    gap: 0.6rem;
    margin-bottom: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);
    flex-wrap: wrap;
  }
  .type-option {
    display: flex !important;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--el-ui) !important;
    font-weight: 500 !important;
    font-size: 12px !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    color: var(--el-text-soft) !important;
    cursor: pointer;
    padding: 0.55rem 1rem;
    border: 1px solid var(--el-rule);
    transition: border-color 0.2s ease, color 0.2s ease;
    margin: 0 !important;
  }
  .type-option:has(input:checked) {
    border-color: var(--el-accent);
    color: var(--el-text) !important;
  }
  .type-option input[type="radio"] {
    width: auto;
    accent-color: var(--el-accent);
  }

  .step-next,
  .step-submit {
    margin-top: clamp(1.25rem, 1rem + 0.75vw, 1.75rem);
    padding: 0.6rem 1.6rem;
    background: transparent;
    color: var(--el-accent);
    border: 1px solid var(--el-accent);
    font-family: var(--el-ui);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .step-next:hover,
  .step-submit:hover {
    background: var(--el-accent);
    color: var(--el-bg);
  }
  .step-submit:disabled { opacity: 0.55; cursor: wait; }

  .mt-md { margin-top: clamp(0.85rem, 0.7rem + 0.4vw, 1.2rem); }

  .step-progress {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-top: clamp(2rem, 1.5rem + 1.5vw, 3rem);
  }
  .progress-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--el-rule);
    transition: background 0.2s ease, opacity 0.2s ease;
  }
  .progress-dot.active { background: var(--el-accent); }
  .progress-dot.completed {
    background: var(--el-accent);
    opacity: 0.4;
  }

  .step-back {
    display: block;
    margin: 0.85rem auto 0;
    background: none;
    border: none;
    color: var(--el-text-quiet);
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0.5rem 1rem;
  }
  .step-back:hover { color: var(--el-text-soft); }

  .build-status {
    font-family: var(--el-ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 1rem;
    min-height: 1.2em;
    color: var(--el-text-quiet);
  }
  .build-status.success { color: var(--el-accent); }
  .build-status.error   { color: #c44; }

  /* ---- After-form copy ---- */
  .build-aftercopy {
    font-family: var(--el-body);
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem);
    line-height: 1.6;
    color: var(--el-text-soft);
    max-width: 60ch;
    margin: 0;
  }
  .build-aftercopy-cta {
    margin-top: clamp(1.5rem, 1rem + 1.5vw, 2.5rem) !important;
  }

  @media (max-width: 480px) {
    .type-options { gap: 0.45rem; }
    .type-option { padding: 0.5rem 0.85rem; }
  }
</style>
