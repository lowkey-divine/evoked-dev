---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout title="Build With Us" description="Tell us about the app you want to build. Sovereignty-honoring software starts with a conversation.">
  <div class="hero-small">
    <h1>Tell us what you want to build.</h1>
    <p class="tagline">Every app we build honors the people who use it. If that matters to you, we should talk.</p>
  </div>

  <section class="container">
    <form id="build-form" class="build-form">
      <div class="form-group">
        <label for="build-name">Your name</label>
        <input type="text" id="build-name" name="name" required />
      </div>

      <div class="form-group">
        <label for="build-email">Your email</label>
        <input type="email" id="build-email" name="email" required />
      </div>

      <div class="form-group">
        <label for="build-idea">What do you want to build?</label>
        <textarea id="build-idea" name="idea" rows="5" required placeholder="Tell us about the app, the problem it solves, and why it matters to you."></textarea>
      </div>

      <div class="form-group">
        <label for="build-audience">Who does it serve?</label>
        <textarea id="build-audience" name="audience" rows="3" placeholder="The people, families, or communities this is for."></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Send it over</button>
      <p id="build-status" class="build-status" aria-live="polite"></p>
    </form>
  </section>

  <section class="container">
    <div class="what-happens">
      <h2>What happens next</h2>
      <p>I read every submission personally. If there is a fit, I will reach out within a few days to start a conversation about scope, timeline, and how we might work together. If the fit is not right, I will tell you honestly and point you somewhere better if I can.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('build-form') as HTMLFormElement;
  const status = document.getElementById('build-status') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = '';

    const name = (document.getElementById('build-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('build-email') as HTMLInputElement).value.trim();
    const idea = (document.getElementById('build-idea') as HTMLTextAreaElement).value.trim();
    const audience = (document.getElementById('build-audience') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !idea) return;

    const button = form.querySelector('button') as HTMLButtonElement;
    button.disabled = true;
    button.textContent = 'Sending...';

    try {
      const res = await fetch('/api/build-with-us', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, idea, audience }),
      });

      if (res.ok) {
        status.textContent = 'Received. I will be in touch.';
        status.className = 'build-status success';
        form.reset();
      } else {
        const data = await res.json();
        status.textContent = data.error || 'Something went wrong. Try again.';
        status.className = 'build-status error';
      }
    } catch {
      status.textContent = 'Something went wrong. Try again.';
      status.className = 'build-status error';
    } finally {
      button.disabled = false;
      button.textContent = 'Send it over';
    }
  });
</script>

<style>
  .hero-small {
    text-align: center;
    padding: var(--space-lg) var(--space-md);
  }

  .hero-small h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-xs);
  }

  .hero-small .tagline {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .build-form {
    max-width: 560px;
    margin: 0 auto;
  }

  .form-group {
    margin-bottom: var(--space-md);
  }

  .form-group label {
    display: block;
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: var(--space-xs);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    background: transparent;
    color: var(--text-primary);
    font-family: inherit;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent-warm);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted);
  }

  .form-group textarea {
    resize: vertical;
  }

  .btn-primary {
    background: var(--accent-warm);
    color: var(--bg-deep);
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--accent-glow);
    color: var(--bg-deep);
  }

  .build-status {
    font-size: 0.85rem;
    margin-top: var(--space-sm);
    min-height: 1.2em;
  }

  .build-status.success {
    color: var(--accent-warm);
  }

  .build-status.error {
    color: #e57373;
  }

  .what-happens {
    max-width: 560px;
    margin: var(--space-lg) auto 0;
  }

  .what-happens h2 {
    font-size: 1.3rem;
    margin-bottom: var(--space-sm);
  }

  .what-happens p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
</style>
