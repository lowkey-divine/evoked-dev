# Anthropic API Key for AI chat features
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Stripe — for webhook signature verification
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from: https://dashboard.stripe.com/webhooks (after creating endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — for transactional email delivery (Stripe product emails)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# beehiiv - for newsletter subscriber management (switched from Buttondown 2026-06-16)
# Get API key from: https://app.beehiiv.com/settings/integrations/api
# Get publication ID from: app.beehiiv.com (publication settings, format: pub_xxx)
BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Form security — HMAC secret for challenge tokens (anti-bot/anti-spam)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FORM_SECRET=your-random-secret-here
